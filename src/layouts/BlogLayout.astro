---
/**
 * Тонкая обёртка над BlogShell.
 *
 * Оставлена ради обратной совместимости: 15 статей передают плоские пропы
 * (title/description/pubDate/...) — их файлы не трогаем. Весь дизайн и
 * интерактив живут в BlogShell.astro, поэтому обе группы статей выглядят одинаково.
 */
import BlogShell from './BlogShell.astro';

const { title, description, pubDate, image, ogImage, category, readTime } = Astro.props;

// Раньше здесь по умолчанию подставлялся логотип (для og-картинки). Как ОБЛОЖКУ его
// брать нельзя — логотип, растянутый на весь экран, выглядит сломанным.
// Поэтому в hero отдаём только настоящую картинку статьи, а логотип оставляем для og.
const cover = image && !/logo\.(png|svg|jpe?g)/i.test(image) ? image : '';
---

<BlogShell
    title={title}
    description={description}
    category={category}
    date={pubDate}
    readTime={readTime}
    image={cover}
    ogImage={ogImage || image}
>
    <slot />
</BlogShell>

---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
	title: string;
    description?: string;
    keywords?: string;
    canonicalURL?: string;
    navTheme?: 'default' | 'dark';
    ogImage?: string;
    ogImageWidth?: number;
    ogImageHeight?: number;
    ogType?: 'website' | 'article';
}

const {
    title,
    description = "BizPride — закрытый бизнес-клуб для предпринимателей Алматы. Мастермайнды, нетворкинг, бизнес-бранчи. Гостевой визит — бесплатно.",
    keywords = "бизнес клуб Алматы, клуб для предпринимателей в Алматы, предприниматели Алматы, мастермайнд Алматы, нетворкинг Алматы, бизнес сообщество Казахстан, BizPride, Biz Pride, biz pride, BizPride Club, Biz Pride Club, BizPraid, БизПрайд, Биз Прайд, бизпрайд, бизпрайд клуб, Бис Прайт",
    canonicalURL = Astro.url.href,
    navTheme = 'default',
    ogImage = '/og/og-default.png',
    ogImageWidth = 1200,
    ogImageHeight = 630,
    ogType = 'website'
} = Astro.props;

const currentPath = Astro.url.pathname;
// Absolute URL for OG/Twitter images (works for both relative and absolute input)
const ogImageURL = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        <link rel="alternate" hreflang="ru" href={canonicalURL} />
        <link rel="alternate" hreflang="x-default" href={canonicalURL} />

        <!-- SEO -->
        <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
        <meta name="theme-color" content="#c42b2b" />
        <meta name="author" content="BizPride Club" />
        <meta name="language" content="Russian" />
        <meta name="geo.region" content="KZ-ALA" />
        <meta name="geo.placename" content="Almaty" />
        <meta name="keywords" content={keywords} />
        
        <!-- Open Graph -->
        <meta property="og:type" content={ogType} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:site_name" content="BizPride Club" />
        <meta property="og:locale" content="ru_KZ" />
        <meta property="og:image" content={ogImageURL} />
        <meta property="og:image:width" content={String(ogImageWidth)} />
        <meta property="og:image:height" content={String(ogImageHeight)} />
        <meta property="og:image:alt" content={title} />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageURL} />

        <!-- JSON-LD Structured Data -->
        <script type="application/ld+json" set:html={JSON.stringify([
            {
                "@context": "https://schema.org",
                "@type": "Organization",
                "@id": "https://bizpride.kz/#organization",
                "name": "BizPride Club",
                "alternateName": ["БизПрайд", "Биз Прайд", "БизПрайд Клуб", "бизпрайд", "Бис Прайт", "Biz Pride", "Biz Pride Club", "BizPraid"],
                "url": "https://bizpride.kz",
                "logo": {
                    "@type": "ImageObject",
                    "@id": "https://bizpride.kz/#logo",
                    "url": "https://bizpride.kz/logo.png",
                    "contentUrl": "https://bizpride.kz/logo.png",
                    "caption": "BizPride Club"
                },
                "description": "Закрытый бизнес-клуб для предпринимателей в Алматы. Нетворкинг, мастермайнды, менторство.",
                "address": {
                    "@type": "PostalAddress",
                    "addressLocality": "Алматы",
                    "addressCountry": "KZ"
                },
                "contactPoint": {
                    "@type": "ContactPoint",
                    "telephone": "+7-707-035-7777",
                    "contactType": "customer service",
                    "availableLanguage": ["Russian", "Kazakh"]
                },
                "sameAs": [
                    "https://wa.me/77070357777"
                ]
            },
            {
                "@context": "https://schema.org",
                "@type": "LocalBusiness",
                "name": "BizPride Club",
                "alternateName": ["БизПрайд", "Биз Прайд", "БизПрайд Клуб", "бизпрайд", "Biz Pride", "Biz Pride Club"],
                "image": "https://bizpride.kz/img-mastermind.png",
                "description": "Бизнес-клуб BizPride — сообщество сильных предпринимателей Алматы. Мастермайнды, бизнес-бранчи, инвестиционный клуб и ценный нетворкинг.",
                "address": {
                    "@type": "PostalAddress",
                    "addressLocality": "Алматы",
                    "addressRegion": "Алматинская область",
                    "addressCountry": "KZ"
                },
                "priceRange": "₸₸₸",
                "telephone": "+7-707-035-7777",
                "url": "https://bizpride.kz"
            }
        ])} />

        <!-- Optimize Google Fonts, YouTube thumbnails, and preload hero image -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="preconnect" href="https://i.ytimg.com" crossorigin />
        <link rel="dns-prefetch" href="https://img.youtube.com" />
        <link rel="dns-prefetch" href="https://www.youtube.com" />
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,700&display=swap" />
        
        {currentPath === '/' && (
            <link rel="preload" as="image" href="/founder.webp" type="image/webp" fetchpriority="high" />
        )}

        <ViewTransitions />

        <!-- Yandex.Metrika counter (id: 108838020) — async, no render block -->
        <script is:inline>
            (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
            m[i].l=1*new Date();
            for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
            k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
            (window, document, "script", "https://mc.yandex.ru/metrika/tag.js?id=108838020", "ym");

            ym(108838020, "init", {
                ssr:true,
                webvisor:true,
                clickmap:true,
                ecommerce:"dataLayer",
                accurateTrackBounce:true,
                trackLinks:true
            });
        </script>
        <noscript><div><img src="https://mc.yandex.ru/watch/108838020" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
        <!-- /Yandex.Metrika counter -->

        <!-- Google Analytics 4 (G-PTCSV0Q73E) — async, no render block -->
        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-PTCSV0Q73E"></script>
        <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-PTCSV0Q73E', {
                send_page_view: true,
                anonymize_ip: true
            });
        </script>
        <!-- /Google Analytics 4 -->
	</head>
	<body>
        <Navigation currentPath={currentPath} theme={navTheme} />
        <slot />
        <Footer />

        <!-- Mobile-only sticky WhatsApp CTA (site-wide). Auto-tracked by the wa.me click handler below. -->
        <a
            href="https://wa.me/77070357777?text=%D0%97%D0%B4%D1%80%D0%B0%D0%B2%D1%81%D1%82%D0%B2%D1%83%D0%B9%D1%82%D0%B5!%20%D0%A5%D0%BE%D1%87%D1%83%20%D1%83%D0%B7%D0%BD%D0%B0%D1%82%D1%8C%20%D0%BE%20%D0%BA%D0%BB%D1%83%D0%B1%D0%B5%20BizPride"
            target="_blank"
            rel="noopener"
            class="wa-sticky-cta"
            aria-label="Написать в WhatsApp"
        >
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            <span>Написать в WhatsApp</span>
        </a>

        <!-- GA4 WhatsApp click tracking — fires custom event 'whatsapp_click'
             on every WhatsApp link across the entire site. Mark this as a
             Conversion in GA4 → Admin → Events → whatsapp_click → ⋮ → Mark as conversion -->
        <script is:inline>
            document.addEventListener('astro:page-load', function() {
                document.querySelectorAll('a[href*="wa.me"]').forEach(function(link) {
                    link.addEventListener('click', function() {
                        if (typeof gtag === 'function') {
                            gtag('event', 'whatsapp_click', {
                                event_category: 'conversion',
                                event_label: link.href,
                                value: 1
                            });
                        }
                        // Метрика: reachGoal
                        if (typeof ym === 'function') {
                            ym(108838020, 'reachGoal', 'whatsapp_click', { url: link.href });
                        }
                    });
                });
            });
        </script>

        <script>
            // Standard Reveal Logic (will work across pages with ViewTransitions)
            function initReveals() {
                const reveals = document.querySelectorAll('.reveal');
                const observer = new IntersectionObserver(entries => {
                    entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
                }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
                reveals.forEach(el => observer.observe(el));
            }

            document.addEventListener('astro:page-load', initReveals);
        </script>
	</body>
</html>

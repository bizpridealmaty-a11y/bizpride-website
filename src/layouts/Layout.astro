---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
	title: string;
    description?: string;
    keywords?: string;
    canonicalURL?: string;
    navTheme?: 'default' | 'dark';
    ogImage?: string;
    ogImageWidth?: number;
    ogImageHeight?: number;
    ogType?: 'website' | 'article';
}

const {
    title,
    description = "BizPride — закрытый бизнес-клуб для предпринимателей Алматы. Мастермайнды, нетворкинг, бизнес-бранчи. Гостевой визит — бесплатно.",
    keywords = "бизнес клуб Алматы, клуб для предпринимателей в Алматы, предприниматели Алматы, мастермайнд Алматы, нетворкинг Алматы, бизнес сообщество Казахстан, BizPride, Biz Pride, biz pride, BizPride Club, Biz Pride Club, BizPraid, БизПрайд, Биз Прайд, бизпрайд, бизпрайд клуб, Бис Прайт",
    canonicalURL = Astro.url.href,
    navTheme = 'default',
    ogImage = '/og/og-default.png',
    ogImageWidth = 1200,
    ogImageHeight = 630,
    ogType = 'website'
} = Astro.props;

const currentPath = Astro.url.pathname;
// Absolute URL for OG/Twitter images (works for both relative and absolute input)
const ogImageURL = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        <link rel="alternate" hreflang="ru" href={canonicalURL} />
        <link rel="alternate" hreflang="x-default" href={canonicalURL} />

        <!-- SEO -->
        <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
        <meta name="theme-color" content="#c42b2b" />
        <meta name="author" content="BizPride Club" />
        <meta name="language" content="Russian" />
        <meta name="geo.region" content="KZ-ALA" />
        <meta name="geo.placename" content="Almaty" />
        <meta name="keywords" content={keywords} />
        
        <!-- Open Graph -->
        <meta property="og:type" content={ogType} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:site_name" content="BizPride Club" />
        <meta property="og:locale" content="ru_KZ" />
        <meta property="og:image" content={ogImageURL} />
        <meta property="og:image:width" content={String(ogImageWidth)} />
        <meta property="og:image:height" content={String(ogImageHeight)} />
        <meta property="og:image:alt" content={title} />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageURL} />

        <!-- JSON-LD Structured Data -->
        <script type="application/ld+json" set:html={JSON.stringify([
            {
                "@context": "https://schema.org",
                "@type": "Organization",
                "@id": "https://bizpride.kz/#organization",
                "name": "BizPride Club",
                "alternateName": ["БизПрайд", "Биз Прайд", "БизПрайд Клуб", "бизпрайд", "Бис Прайт", "Biz Pride", "Biz Pride Club", "BizPraid"],
                "url": "https://bizpride.kz",
                "logo": {
                    "@type": "ImageObject",
                    "@id": "https://bizpride.kz/#logo",
                    "url": "https://bizpride.kz/logo.png",
                    "contentUrl": "https://bizpride.kz/logo.png",
                    "caption": "BizPride Club"
                },
                "description": "Закрытый бизнес-клуб для предпринимателей в Алматы. Нетворкинг, мастермайнды, менторство.",
                "address": {
                    "@type": "PostalAddress",
                    "addressLocality": "Алматы",
                    "addressCountry": "KZ"
                },
                "contactPoint": {
                    "@type": "ContactPoint",
                    "telephone": "+7-707-035-7777",
                    "contactType": "customer service",
                    "availableLanguage": ["Russian", "Kazakh"]
                },
                "sameAs": [
                    "https://wa.me/77070357777"
                ]
            },
            {
                "@context": "https://schema.org",
                "@type": "LocalBusiness",
                "name": "BizPride Club",
                "alternateName": ["БизПрайд", "Биз Прайд", "БизПрайд Клуб", "бизпрайд", "Biz Pride", "Biz Pride Club"],
                "image": "https://bizpride.kz/img-mastermind.png",
                "description": "Бизнес-клуб BizPride — сообщество сильных предпринимателей Алматы. Мастермайнды, бизнес-бранчи, инвестиционный клуб и ценный нетворкинг.",
                "address": {
                    "@type": "PostalAddress",
                    "addressLocality": "Алматы",
                    "addressRegion": "Алматинская область",
                    "addressCountry": "KZ"
                },
                "priceRange": "₸₸₸",
                "telephone": "+7-707-035-7777",
                "url": "https://bizpride.kz"
            }
        ])} />

        <!-- Optimize Google Fonts, YouTube thumbnails, and preload hero image -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="preconnect" href="https://i.ytimg.com" crossorigin />
        <link rel="dns-prefetch" href="https://img.youtube.com" />
        <link rel="dns-prefetch" href="https://www.youtube.com" />
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,700&display=swap" />
        
        {currentPath === '/' && (
            <link rel="preload" as="image" href="/founder.webp" type="image/webp" fetchpriority="high" />
        )}

        <ViewTransitions />

        <!-- Yandex.Metrika counter (id: 108838020) — async, no render block -->
        <script is:inline>
            (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
            m[i].l=1*new Date();
            for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
            k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
            (window, document, "script", "https://mc.yandex.ru/metrika/tag.js?id=108838020", "ym");

            ym(108838020, "init", {
                ssr:true,
                webvisor:true,
                clickmap:true,
                ecommerce:"dataLayer",
                accurateTrackBounce:true,
                trackLinks:true
            });
        </script>
        <noscript><div><img src="https://mc.yandex.ru/watch/108838020" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
        <!-- /Yandex.Metrika counter -->

        <!-- Google Analytics 4 (G-PTCSV0Q73E) — async, no render block -->
        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-PTCSV0Q73E"></script>
        <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-PTCSV0Q73E', {
                send_page_view: true,
                anonymize_ip: true
            });
        </script>
        <!-- /Google Analytics 4 -->
	</head>
	<body>
        <Navigation currentPath={currentPath} theme={navTheme} />
        <slot />
        <Footer />

        <!-- GA4 WhatsApp click tracking — fires custom event 'whatsapp_click'
             on every WhatsApp link across the entire site. Mark this as a
             Conversion in GA4 → Admin → Events → whatsapp_click → ⋮ → Mark as conversion -->
        <script is:inline>
            document.addEventListener('astro:page-load', function() {
                document.querySelectorAll('a[href*="wa.me"]').forEach(function(link) {
                    link.addEventListener('click', function() {
                        if (typeof gtag === 'function') {
                            gtag('event', 'whatsapp_click', {
                                event_category: 'conversion',
                                event_label: link.href,
                                value: 1
                            });
                        }
                        // Метрика: reachGoal
                        if (typeof ym === 'function') {
                            ym(108838020, 'reachGoal', 'whatsapp_click', { url: link.href });
                        }
                    });
                });
            });
        </script>

        <script>
            // Standard Reveal Logic (will work across pages with ViewTransitions)
            function initReveals() {
                const reveals = document.querySelectorAll('.reveal');
                const observer = new IntersectionObserver(entries => {
                    entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
                }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
                reveals.forEach(el => observer.observe(el));
            }

            document.addEventListener('astro:page-load', initReveals);
        </script>
	</body>
</html>

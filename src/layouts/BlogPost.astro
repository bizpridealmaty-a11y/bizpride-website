---
/**
 * Тонкая обёртка над BlogShell.
 *
 * Оставлена ради обратной совместимости: 29 статей передают данные объектом
 * `frontmatter` — их файлы не трогаем. Весь дизайн и интерактив живут в
 * BlogShell.astro, поэтому блог выглядит одинаково независимо от того,
 * какой шаблон импортирует конкретная статья.
 */
import BlogShell from './BlogShell.astro';

const { frontmatter } = Astro.props;
---

<BlogShell
    title={frontmatter.title}
    description={frontmatter.description}
    category={frontmatter.category}
    date={frontmatter.date}
    readTime={frontmatter.readTime}
    image={frontmatter.image}
>
    <slot />
</BlogShell>

<style>
    .footer-main {
        padding-top: 100px;
        padding-bottom: 40px;
        border-top: 1px solid var(--border);
        background: #0a0a0a;
    }
    .footer-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
        gap: 40px;
        margin-bottom: 80px;
    }
    .footer-brand-section {
        max-width: 320px;
    }
    .footer-logo {
        font-size: 24px;
        font-weight: 900;
        letter-spacing: 1px;
        margin-bottom: 24px;
        color: #fff;
    }
    .footer-tagline {
        font-size: 15px;
        line-height: 1.6;
        color: var(--text-muted);
    }
    
    .footer-grid h3 {
        font-size: 13px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #fff;
        margin-bottom: 24px;
    }
    
    .footer-nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .footer-nav li {
        margin-bottom: 12px;
    }
    .footer-nav a, .footer-contacts a, .social-links-text a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 15px;
        transition: color 0.3s;
    }
    .footer-nav a:hover, .footer-contacts a:hover, .social-links-text a:hover {
        color: var(--red);
    }
    
    .footer-contacts p {
        font-size: 15px;
        color: var(--text-muted);
        line-height: 1.6;
        margin-bottom: 12px;
    }
    
    .social-links-text {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .footer-map-wrapper {
        margin-bottom: 60px;
    }

    /* Ensure Sunday popups don't overflow the container on the right */
    @media (min-width: 901px) {
        .cal-day.sunday .cal-popup {
            left: auto;
            right: 0;
            transform: translateX(0) translateY(10px);
        }
        .cal-day.sunday:hover .cal-popup {
            transform: translateX(0) translateY(0);
        }
        .cal-day.sunday .cal-popup::after {
            left: auto;
            right: 40px;
        }
    }

    /* Brand Marker Styles */
    :global(.brand-map-marker) {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    :global(.marker-pin) {
        width: 50px;
        height: 50px;
        background: var(--red);
        border: 4px solid #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(196, 43, 43, 0.4);
        position: relative;
    }

    :global(.marker-pin::after) {
        content: '';
        position: absolute;
        bottom: -10px;
        left: 50%;
        transform: translateX(-50%);
        border-width: 10px 10px 0;
        border-style: solid;
        border-color: #fff transparent transparent;
    }

    :global(.marker-logo) {
        width: 32px;
        height: 32px;
        background: url('/logo.png') no-repeat center center;
        background-size: contain;
        filter: brightness(0) invert(1); /* Make the black logo white */
    }

    :global(.leaflet-popup-content-wrapper) {
        background: #1a1a1a;
        color: #fff;
        border-radius: 12px;
        padding: 5px;
    }

    :global(.leaflet-popup-tip) {
        background: #1a1a1a;
    }

    :global(.leaflet-container) {
        background: #0a0a0a !important;
    }

    .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 40px;
        border-top: 1px solid rgba(255,255,255,0.05);
        font-size: 14px;
        color: var(--text-muted);
    }
    .footer-social-icons {
        display: flex;
        gap: 12px;
    }
    .social-icon {
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 700;
        font-size: 12px;
        transition: all 0.3s;
    }
    .social-icon:hover {
        background: var(--red);
        color: #fff;
        border-color: var(--red);
        transform: translateY(-3px);
    }

    @media (max-width: 991px) {
        .footer-grid {
            grid-template-columns: 1fr 1fr;
            gap: 40px;
        }
    }
    @media (max-width: 576px) {
        .footer-grid {
            grid-template-columns: 1fr 1fr;
            gap: 40px 20px;
        }
        .footer-brand-section {
            grid-column: 1 / -1;
            margin-bottom: 0px;
        }
        .footer-bottom {
            flex-direction: column;
            gap: 24px;
            text-align: center;
        }
    }
</style>

        </div>

        <!-- Interactive Map Integration -->
        <div class="footer-map-wrapper reveal">
            <div id="footer-map" style="height: 350px; border-radius: 24px; overflow: hidden; position: relative;"></div>
            
            <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
            <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
            
            <script is:inline>
                (function() {
                    let mapInstance = null;

                    function initMap() {
                        const container = document.getElementById('footer-map');
                        if (!container || typeof L === 'undefined') {
                            return;
                        }

                        // Protect against double init
                        if (mapInstance) {
                            mapInstance.remove();
                        }

                        const coords = [43.2328, 76.9224];
                        mapInstance = L.map('footer-map', {
                            center: coords,
                            zoom: 17,
                            zoomControl: false,
                            scrollWheelZoom: false
                        });

                        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                            attribution: '&copy; OpenStreetMap contributors &copy; CARTO'
                        }).addTo(mapInstance);

                        const brandIcon = L.divIcon({
                            className: 'brand-map-marker',
                            html: `
                                <div class="marker-pin">
                                    <div class="marker-logo"></div>
                                </div>
                            `,
                            iconSize: [60, 60],
                            iconAnchor: [30, 60]
                        });

                        const marker = L.marker(coords, { icon: brandIcon }).addTo(mapInstance);
                        
                        // Открываем 2GIS при клике на маркер или карту
                        const open2Gis = () => window.open('https://go.2gis.com/DVpGd', '_blank');
                        marker.on('click', open2Gis);
                        mapInstance.on('click', open2Gis);
                        
                        // Делаем карту статичной кнопкой
                        container.style.cursor = 'pointer';
                        mapInstance.dragging.disable();
                        mapInstance.touchZoom.disable();
                        mapInstance.doubleClickZoom.disable();
                        mapInstance.boxZoom.disable();
                        mapInstance.keyboard.disable();
                    }

                    // Work with Astro ViewTransitions
                    document.addEventListener('astro:page-load', initMap);
                    
                    // Fallback for first load
                    if (document.readyState === 'complete') {
                        initMap();
                    } else {
                        window.addEventListener('load', initMap);
                    }
                })();
            </script>
        </div>

        <div class="footer-bottom">

---
import BlogPost from '../../layouts/BlogPost.astro';

const frontmatter = {
  title: "Как управлять бизнесом через цифры в Казахстане? Полная оцифровка вашего бизнеса.",
  description: "Посмотреть полное видео на тему: " + "Как управлять бизнесом через цифры в Казахстане? Полная оцифровка вашего бизнеса.",

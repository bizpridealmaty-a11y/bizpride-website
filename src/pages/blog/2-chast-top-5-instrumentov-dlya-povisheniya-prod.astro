const frontmatter = {
  title: "ТОП-5 инструментов продуктивности для предпринимателя — Геннадий Юрченко",
  description: "Какие 5 инструментов реально влияют на продуктивность собственника бизнеса: тайм-блокинг, ритуалы, делегирование. Практический разбор Геннадия Юрченко на BizPride.",

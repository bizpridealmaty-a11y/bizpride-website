---
import BlogLayout from '../../layouts/BlogLayout.astro';

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "Какие форматы бизнес-обучения есть в Алматы в 2026 году?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Основные форматы: онлайн-курсы (от 30 до 500 тыс. ₸), оффлайн-тренинги (от 50 до 300 тыс. ₸ за модуль), личный коучинг (от 100 тыс. ₸/мес), MBA-программы (от 5 млн ₸/год), мастермайнд-группы в бизнес-клубах (от 500 тыс. ₸/год). Каждый закрывает разные задачи — выбор зависит от вашего текущего уровня и конкретной проблемы."
            }
        },
        {
            "@type": "Question",
            "name": "Чем мастермайнд лучше бизнес-тренинга?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Тренинг — один эксперт передаёт знания группе (вертикальная модель). Мастермайнд — 6-10 равных собственников разбирают конкретно ваш кейс (горизонтальная модель). На тренинге вы получаете общие знания. На мастермайнде — решение вашей конкретной задачи от людей с реальным опытом в 6-10 разных нишах."
            }
        },
        {
            "@type": "Question",
            "name": "Как выбрать бизнес-обучение в Казахстане и не попасть на инфоцыган?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "5 признаков надёжной программы: 1) у автора есть действующий бизнес (не только курсы); 2) реалистичные обещания (не «1 млн за месяц»); 3) структурированная программа с домашними заданиями; 4) кейсы учеников с конкретными цифрами; 5) обратная связь от автора, а не только от ассистента."
            }
        },
        {
            "@type": "Question",
            "name": "Сколько стоит бизнес-обучение для предпринимателя в Алматы?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "От 0 ₸ (бесплатные конференции, YouTube-контент) до 10+ млн ₸ (MBA, Executive-программы). Средний бюджет для собственника МСБ — 500 тыс. – 2 млн ₸ в год, включая членство в бизнес-клубе + 1-2 целевых курса. Главное — не тратить на «волшебные таблетки», а инвестировать в структурированные программы."
            }
        }
    ]
};

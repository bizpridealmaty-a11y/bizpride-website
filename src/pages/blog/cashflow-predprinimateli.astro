  .seo-article .hero-tag { display: inline-block; background: var(--purple); color: #fff; font-size: 0.7rem; font-weight: 900; letter-spacing: 2px; text-transform: uppercase; padding: 4px 14px; margin-bottom: 20px; }
  .seo-article .hero-title { font-size: clamp(1.9rem, 4vw, 3.2rem); font-weight: 900; line-height: 1.1; color: var(--white); margin-bottom: 18px; }

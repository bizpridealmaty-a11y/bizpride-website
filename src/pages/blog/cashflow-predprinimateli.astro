  .seo-article .article-body h3 { font-size: 1.1rem; font-weight: 700; color: var(--white); margin: 30px 0 12px; }
  .seo-article .article-body p { margin-bottom: 22px; font-size: 1rem; }
  .seo-article .article-body strong { color: var(--white); font-weight: 600; }
  .seo-article .inline-img { width: 100%; border-radius: 12px; margin: 36px 0; aspect-ratio: 16/7; object-fit: cover; opacity: 0.88; }

  /* КВАДРАНТ */
  .seo-article .quadrant { display: grid; grid-template-columns: 1fr 1fr; gap: 3px; margin: 36px 0; border: 1px solid var(--border); border-radius: 12px; overflow: hidden;}
  .seo-article .q-cell { padding: 28px; background: var(--surface); }

  .seo-article .q-cell .letter { font-size: 2.4rem; font-weight: 900; color: var(--border); line-height: 1; margin-bottom: 8px; }
  .seo-article .q-cell.active .letter { color: var(--accent); }
  .seo-article .q-cell .name { font-size: 1rem; font-weight: 700; color: var(--white); margin-bottom: 6px; }
  .seo-article .q-cell .desc { font-size: 0.85rem; color: var(--muted); line-height: 1.6; }

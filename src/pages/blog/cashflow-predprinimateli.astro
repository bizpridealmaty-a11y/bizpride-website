  .seo-article .q-axis-h { display: flex; justify-content: space-around; margin-bottom: 3px; }
  .seo-article .q-axis-v { position: absolute; left: 24px; top: 50%; transform: translate(-50%, -50%) rotate(-90deg); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px; color: var(--muted); font-weight: 600; white-space: nowrap; }

  /* INSIGHTS */
  .seo-article .insight-list { display: flex; flex-direction: column; gap: 20px; margin: 36px 0; }

  .seo-article .quote-text { font-size: 1.1rem; font-style: italic; color: var(--white); margin-bottom: 10px; line-height: 1.6; }
  .seo-article .quote-author { font-size: 0.82rem; color: var(--muted); font-weight: 600; }


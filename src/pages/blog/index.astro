---
import Layout from '../../layouts/Layout.astro';
import posts from '../../data/blogPosts.json';
---

<Layout 
    title="Блог о клубе BizPride — Статьи, аналитика и новости"
    description="Читайте полезные статьи от резидентов бизнес-клуба BizPride. Экспертика в бизнесе, маркетинге, налогах и менеджменте для предпринимателей Казахстана."
>
    <section class="section-dark" style="padding-top: 180px;">
        <div class="container">
            <div class="gallery-header" style="flex-direction: column; align-items: flex-start; gap: 24px; margin-bottom: 80px;">
                <div>
                    <div class="label reveal" style="margin-bottom: 16px;">Полезные материалы</div>
                    <h1 class="heading-lg reveal reveal-d1" style="font-size: clamp(40px, 6vw, 72px); line-height: 1.05; letter-spacing: -2px;">Блог о<br>клубе</h1>
                </div>
                <p class="reveal reveal-d2" style="color: var(--text-light); font-size: 18px; max-width: 640px; line-height: 1.7; opacity: 0.8;">
                    Здесь мы собираем ценный опыт наших резидентов, разбираем кейсы, делимся новостями клуба и публикуем полезные материалы для роста вашего бизнеса.
                </p>
            </div>

            <div class="blog-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 40px;">
                {posts.map((post, index) => (
                    <a href={post.slug} class={`blog-card reveal ${index > 0 ? 'reveal-d' + Math.min(index, 3) : ''}`} style="display: flex; flex-direction: column; text-decoration: none; background: #111; border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; overflow: hidden; transition: transform 0.3s, border-color 0.3s;">
                        {post.image && (
                            <div style="width: 100%; height: 200px; overflow: hidden; border-bottom: 1px solid rgba(255,255,255,0.05);">
                                <img src={post.image} alt={post.title} style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;" class="blog-image"/>
                            </div>
                        )}
                        <div style="padding: 30px; display: flex; flex-direction: column; height: 100%;">
                            <div style="font-size: 13px; color: var(--text-muted); margin-bottom: 16px;">
                                {new Date(post.pubDate).toLocaleDateString('ru-RU')}
                            </div>
                            <h3 style="font-size: 22px; color: #fff; margin-bottom: 16px; line-height: 1.3;">{post.title}</h3>
                            <p style="color: var(--text-muted); font-size: 15px; line-height: 1.6; margin-bottom: 24px; flex-grow: 1;">
                                {post.description.substring(0, 120)}{post.description.length > 120 ? '...' : ''}
                            </p>
                            <div style="color: var(--red); font-weight: 600; font-size: 14px; display: flex; align-items: center; gap: 8px;">
                                Читать статью <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </section>
</Layout>

<style>
    .blog-card:hover {
        transform: translateY(-5px);
        border-color: rgba(255,255,255,0.15);
    }
</style>

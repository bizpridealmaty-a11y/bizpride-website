---
import Layout from '../../layouts/Layout.astro';
import posts from '../../data/blogPosts.json';

const blogSchema = {
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "BizPride — База знаний для предпринимателей Алматы",
    "description": "Бизнес-клуб и сообщество предпринимателей Алматы. Статьи, разборы, видео-подкасты о мастермайндах, нетворкинге, продажах, лидерстве и развитии бизнеса в Казахстане.",
    "url": "https://bizpride.kz/blog/",
    "inLanguage": "ru-KZ",
    "publisher": {
        "@type": "Organization",
        "name": "BizPride Club",
        "url": "https://bizpride.kz",
        "logo": {
            "@type": "ImageObject",
            "url": "https://bizpride.kz/logo.png"
        }
    },
    "blogPost": posts.slice(0, 20).map(p => ({
        "@type": "BlogPosting",
        "headline": p.title,
        "url": `https://bizpride.kz${p.slug.endsWith('/') ? p.slug : p.slug + '/'}`,
        "datePublished": p.pubDate,
        "image": p.image
    }))
};

const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://bizpride.kz/" },
        { "@type": "ListItem", "position": 2, "name": "Блог", "item": "https://bizpride.kz/blog/" }
    ]
};
---

<Layout
    title="BizPride — Бизнес-клуб и сообщество предпринимателей Алматы | База знаний"
    description="BizPride — бизнес-клуб и деловое сообщество предпринимателей Алматы. Мастермайнды, нетворкинг, менторство. Полная база знаний о бизнес-клубах и сообществах Казахстана."
>
<script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
<style>
  .seo-hub-container {
      --bg: #0d0f14;
      --surface: #161922;
      --border: #252a36;
      --accent: #f5a623;
      --text: #e8eaf0;
      --muted: #7b8299;
      --white: #ffffff;
      padding-top: 100px;
  }
  .hero-wrap { max-width:1200px;margin:0 auto;padding:80px 60px 60px;display:grid;grid-template-columns:1.1fr 1fr;gap:60px;align-items:center; }
  .hero-badge { display:inline-flex;align-items:center;gap:8px;background:rgba(245,166,35,0.1);border:1px solid rgba(245,166,35,0.3);padding:6px 14px;margin-bottom:24px; }
  .dot { width:6px;height:6px;background:var(--accent);border-radius:50%;animation:pulse 2s ease-in-out infinite; }
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}
  .badge-t { font-size:0.72rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--accent); }
  .hero-title { font-size:clamp(2rem,4vw,3rem);font-weight:900;color:var(--white);line-height:1.1;margin-bottom:20px; }
  .hero-title em { color:var(--accent);font-style:normal; }
  .hero-desc { font-size:1rem;color:var(--muted);margin-bottom:32px; }
  .stats { display:flex;gap:32px;margin-bottom:32px; }
  .stat-n { font-size:2rem;font-weight:900;color:var(--white); }
  .stat-l { font-size:0.72rem;text-transform:uppercase;letter-spacing:1px;color:var(--muted);font-weight:600; }
  .btns { display:flex;gap:12px; }
  .bp { background:var(--accent);color:#000;font-weight:900;font-size:0.82rem;letter-spacing:1.5px;text-transform:uppercase;padding:13px 28px; text-decoration: none; display: inline-block;}
  .bp:hover { background:#ffc04d; }
  .bo { border:1px solid var(--border);color:var(--muted);font-weight:600;font-size:0.82rem;letter-spacing:1px;text-transform:uppercase;padding:13px 28px;transition:border-color 0.2s,color 0.2s; text-decoration: none; display: inline-block;}
  .bo:hover { border-color:var(--accent);color:var(--accent); }
  .hi { position:relative; }
  .hi img { width:100%;aspect-ratio:4/3;object-fit:cover;opacity:0.85; border-radius: 12px; }
  .hf { position:absolute;bottom:-16px;left:-16px;background:var(--accent);padding:16px 20px; border-radius: 8px; }
  .hf .big { font-size:1.6rem;font-weight:900;color:#000;line-height:1; }
  .hf .sm { font-size:0.68rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:rgba(0,0,0,0.6); }

  .cb { max-width:1200px;margin:0 auto;padding:0 60px 40px;display:flex;gap:10px;flex-wrap:wrap; }
  .ct { font-size:0.72rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:5px 14px;border:1px solid var(--border);color:var(--muted); border-radius: 4px; }
  .ct.on { border-color:var(--accent);color:var(--accent);background:rgba(245,166,35,0.06); }

  .sec { max-width:1200px;margin:0 auto;padding:20px 60px 60px; }
  .sh { margin-bottom:28px;padding-bottom:20px;border-bottom:1px solid var(--border);display:flex;align-items:flex-end;justify-content:space-between; }
  .sc { font-size:0.68rem;font-weight:900;letter-spacing:2px;text-transform:uppercase;padding:3px 10px;margin-bottom:8px;display:inline-block; border-radius: 4px; }
  .c1 { background:rgba(245,166,35,0.15);color:var(--accent); }
  .c2 { background:rgba(38,166,154,0.15);color:#26a69a; }
  .c3 { background:rgba(155,109,255,0.15);color:#9b6dff; }
  .st { font-size:1.6rem;font-weight:900;color:var(--white); }
  .sd { font-size:0.88rem;color:var(--muted);margin-top:4px; }
  .ac { font-size:0.82rem;color:var(--muted);font-weight:600; }

  .fr { display:grid;grid-template-columns:1.6fr 1fr;gap:20px;margin-bottom:20px; }
  .fc { background:var(--surface);border:1px solid var(--border);overflow:hidden;display:grid;grid-template-columns:1.2fr 1fr;transition:border-color 0.2s; border-radius: 12px; text-decoration: none;}
  .fc:hover { border-color:var(--accent); }
  .fci { width:100%;height:100%;object-fit:cover;opacity:0.8;display:block;min-height:240px; }
  .fcb { padding:28px;display:flex;flex-direction:column;justify-content:space-between; }
  .fb { display:inline-block;font-size:0.62rem;font-weight:900;letter-spacing:2px;text-transform:uppercase;padding:3px 10px;background:var(--accent);color:#000;margin-bottom:14px; border-radius: 4px; }
  .ft { font-size:1.15rem;font-weight:900;color:var(--white);line-height:1.35;margin-bottom:10px; }
  .fd { font-size:0.84rem;color:var(--muted); }
  .fm { font-size:0.76rem;color:var(--muted);margin-top:16px;display:flex;justify-content:space-between; }
  .ss { display:flex;flex-direction:column;gap:20px; }
  .mc { background:var(--surface);border:1px solid var(--border);padding:20px;display:flex;gap:14px;transition:border-color 0.2s;align-items:flex-start;flex:1; border-radius: 12px; text-decoration: none;}
  .mc:hover { border-color:var(--accent); }
  .mci { width:72px;height:64px;object-fit:cover;flex-shrink:0;opacity:0.8; border-radius: 8px;}
  .mt { font-size:0.65rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--accent);margin-bottom:5px; }
  .mn { font-size:0.9rem;font-weight:700;color:var(--white);line-height:1.35; }
  .g3 { display:grid;grid-template-columns:repeat(3,1fr);gap:20px; }
  .g2 { display:grid;grid-template-columns:repeat(2,1fr);gap:20px; }
  .ca { background:var(--surface);border:1px solid var(--border);overflow:hidden;transition:border-color 0.2s,transform 0.2s; border-radius: 12px; text-decoration: none;}
  .ca:hover { border-color:var(--accent);transform:translateY(-3px); }
  .cai { width:100%;aspect-ratio:16/9;object-fit:cover;opacity:0.8;display:block; }
  .cab { padding:20px; }
  .cat { font-size:0.65rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:8px; }
  .can { font-size:0.95rem;font-weight:700;color:var(--white);line-height:1.4;margin-bottom:12px; }
  .cam { font-size:0.76rem;color:var(--muted);display:flex;justify-content:space-between; }
  .arr { color:var(--accent); }

  .ctas { background:linear-gradient(135deg,#161922 0%,#1e2432 100%);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:80px 60px;text-align:center; }
  .ctas h2 { font-size:clamp(1.6rem,3vw,2.4rem);font-weight:900;color:var(--white);margin-bottom:16px; }
  .ctas p { font-size:1rem;color:var(--muted);max-width:480px;margin:0 auto 32px; }
  .cbts { display:flex;gap:16px;justify-content:center; }

  @media(max-width:1024px){
    .seo-hub-container .fr{grid-template-columns:1fr} .seo-hub-container .fc{grid-template-columns:1fr} .seo-hub-container .fci{min-height:200px;max-height:220px}
    .seo-hub-container .ss{flex-direction:row} .seo-hub-container .g3{grid-template-columns:repeat(2,1fr)}
  }
  @media(max-width:768px){
    .seo-hub-container .hero-wrap{grid-template-columns:1fr;padding:50px 20px 40px;gap:40px} .seo-hub-container .hi{display:none}
    .seo-hub-container .cb{padding:0 20px 30px} .seo-hub-container .sec{padding:20px 20px 50px}
    .seo-hub-container .fr{grid-template-columns:1fr} .seo-hub-container .ss{flex-direction:column}
    .seo-hub-container .g3, .seo-hub-container .g2{grid-template-columns:1fr}
    .seo-hub-container .ctas{padding:60px 20px} .seo-hub-container .cbts{flex-direction:column;align-items:center}
  }

  .blog-card:hover { transform: translateY(-5px); border-color: rgba(255,255,255,0.15); }
</style>

<div class="seo-hub-container">
  <div style="max-width:1200px;margin:0 auto;">
    <div class="hero-wrap">
      <div>
        <div class="hero-badge"><div class="dot"></div><span class="badge-t">База знаний BizPride · Алматы</span></div>

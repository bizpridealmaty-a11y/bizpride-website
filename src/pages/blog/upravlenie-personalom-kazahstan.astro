---
import BlogLayout from '../../layouts/BlogLayout.astro';

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        { "@type": "Question", "name": "Какие главные ошибки управления персоналом в МСБ Казахстана?", "acceptedAnswer": { "@type": "Answer", "text": "5 главных ошибок: 1) зарплата ниже рынка + штрафы = текучка 60%+; 2) KPI на 15 показателей — сотрудник не может посчитать свою зарплату; 3) нет описанных должностных инструкций (работает «по ситуации»); 4) найм через hh.kz без проверки ценностей и культурного fit; 5) отсутствие onboarding — новый сотрудник 2 недели «сам разбирается»." } },
        { "@type": "Question", "name": "Как правильно мотивировать сотрудников без штрафов?", "acceptedAnswer": { "@type": "Answer", "text": "4 правила рабочей мотивации: 1) простота — сотрудник считает зарплату за 1 минуту на калькуляторе; 2) связь с результатом компании — если он зарабатывает больше, компания тоже; 3) сотрудник реально влияет на свою метрику; 4) стоимость учёта метрики дешевле выгоды от управления ей." } },
        { "@type": "Question", "name": "Сколько должен стоить хороший сотрудник в Казахстане?", "acceptedAnswer": { "@type": "Answer", "text": "Общее правило: оклад на уровне 70-80% рынка + бонус за результат, который потенциально выводит общий доход на 110-130% рынка. Это меняет психологию с «убежать» на «остаться и заработать». Зарплата ниже рынка — это НЕ экономия, это скрытый расход на текучку (найм + обучение + потери от ошибок)." } },
        { "@type": "Question", "name": "Как найти сильных сотрудников в Алматы?", "acceptedAnswer": { "@type": "Answer", "text": "Найм сегодня — это маркетинг. Сильные кандидаты выбирают компанию, а не наоборот. 3 рычага: 1) бренд работодателя (офис, культура, соцсети); 2) рекомендации от текущих сотрудников (реферальный бонус); 3) нетворкинг в бизнес-клубах — часто лучшие кандидаты приходят по знакомству через резидентов." } }
    ]
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<BlogLayout
    image="/blog-covers/upravlenie-personalom-kazahstan.jpg"
    title="Управление персоналом в МСБ Казахстана: 5 ошибок и решения"
    description="Как управлять командой в малом и среднем бизнесе Казахстана: мотивация без штрафов, найм сильных, KPI для МСБ. 5 типичных ошибок и решения от BizPride."
    pubDate="2026-05-06T04:00:00+05:00"
    wordCount={2300}
>
    <p class="lead" style="font-size: 22px; color: #fff; font-weight: 600; margin-bottom: 40px;">
        «Люди — главный ресурс» — фраза, которую говорит каждый собственник и при этом делает всё, чтобы лучшие сотрудники ушли к конкурентам. Зарплата ниже рынка, штрафы за опоздания, KPI на 15 показателей — классический набор ошибок МСБ в Казахстане. Этот гайд — про то, как строить команду, которая остаётся и приносит результат.
    </p>

    <h2>5 главных ошибок управления персоналом в МСБ</h2>

    <table style="width: 100%; border-collapse: collapse; margin: 24px 0; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; overflow: hidden;">

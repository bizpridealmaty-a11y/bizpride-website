  // Сообщество
  'chto-takoe-biznes-soobshchestvo': 'community',
  'business-soobschestvo-almaty': 'community',
  'luchshie-soobshchestva-predprinimatelej': 'community',
  'zakrytoe-soobshchestvo-predprinimatelej': 'community',

  // Финансы и капитал
  'kak-razvivat-biznes-cherez-investitsii-v-kazahstan': 'finance',
  'kak-prodat-svoi-biznes-dorogo-aleksandr-shashkin': 'finance',
  'pochemu-pokupayut-franshizi-alimzhan-bazavdinov-v': 'finance',
  'nalogovaya-realnost-2026-chto-zhdet-biznes-v-kaza': 'finance',
  // Мышление и развитие
  'oratorskoe-iskusstvo-kak-govorit-chtobi-vam-veri': 'mindset',

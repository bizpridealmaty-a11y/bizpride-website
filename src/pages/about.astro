<script>
    document.addEventListener('astro:page-load', () => {
        const tabs = document.querySelectorAll('.ed-nav-btn');
        const cards = document.querySelectorAll('.blog-item');
        const loadMoreBtn = document.getElementById('load-more-btn');
        
        const CARDS_PER_PAGE = 6;
        let visibleCount = CARDS_PER_PAGE;
        let currentFilter = 'all';

        function updateCardsDisplay() {
            let matches = 0;
            cards.forEach(card => {
                const category = card.getAttribute('data-category');
                if (currentFilter === 'all' || currentFilter === category) {
                    if (matches < visibleCount) {
                        card.style.display = 'flex';
                    } else {
                        card.style.display = 'none';
                    }
                    matches++;
                } else {
                    card.style.display = 'none';
                }
            });

            if (loadMoreBtn) {
                if (matches > visibleCount) {
                    loadMoreBtn.style.display = 'inline-block';
                } else {
                    loadMoreBtn.style.display = 'none';
                }
            }
        }

        // Initialize display
        updateCardsDisplay();

        if (loadMoreBtn) {
            const newBtn = loadMoreBtn.cloneNode(true);
            loadMoreBtn.parentNode.replaceChild(newBtn, loadMoreBtn);
            
            newBtn.addEventListener('click', (e) => {
                e.preventDefault();
                visibleCount += CARDS_PER_PAGE;
                updateCardsDisplay();
            });
        }

        tabs.forEach(tab => {
            const newTab = tab.cloneNode(true);
            tab.parentNode.replaceChild(newTab, tab);

            newTab.addEventListener('click', (e) => {
                e.preventDefault();
                const currentTabs = document.querySelectorAll('.ed-nav-btn');
                currentTabs.forEach(t => t.classList.remove('active'));
                newTab.classList.add('active');

                currentFilter = newTab.getAttribute('data-filter');
                visibleCount = CARDS_PER_PAGE; // Reset visible count when changing categories
                updateCardsDisplay();
            });
        });
    });
</script>


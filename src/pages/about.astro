---
import Layout from '../layouts/Layout.astro';
import BlogTeaser from '../components/BlogTeaser.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import founderImg from '../assets/founder.webp';
import mastermindImg from '../assets/img-mastermind-new-3.webp';
import networkingImg from '../assets/img-networking-new-2.webp';

// AboutPage + Breadcrumb schema (Organization уже описана в Layout через @id)
const aboutSchema = {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "О клубе BizPride",
    "description": "BizPride — открытый бизнес-клуб для предпринимателей Алматы: мастермайнды, бизнес-бранчи, нетворкинг и совет директоров.",
    "url": "https://bizpride.kz/about/",
    "mainEntity": { "@id": "https://bizpride.kz/#organization" }
};
const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://bizpride.kz/" },
        { "@type": "ListItem", "position": 2, "name": "О клубе", "item": "https://bizpride.kz/about/" }
    ]
};

const stats = [
    { value: '120+', label: 'Резидентов клуба' },
    { value: '50+', label: 'Приглашённых спикеров' },
    { value: '4.8/5', label: 'Рейтинг NPS' },
    { value: '$1M+', label: 'Оборот участников' },
];

const formats = [
    { title: 'Бизнес-бранч', when: 'Каждую субботу', text: 'Открытый формат делового общения за завтраком: спикер, нетворкинг, знакомство с резидентами. Можно прийти гостем без обязательств.', href: '/blog/business-meropriyatiya-almaty-2026/', cta: 'Календарь встреч' },
    { title: 'Совет директоров', when: 'Каждый вторник', text: 'Закрытый мастермайнд для резидентов: фокус-группа из 6–10 собственников по жёсткому регламенту разбирает реальные кейсы участников.', href: '/blog/chto-takoe-mastermind/', cta: 'Что такое мастермайнд' },
    { title: 'Игры Cashflow', when: 'Раз в месяц', text: 'Турниры по финансовой игре в нашей казахстанской версии — отрабатываем денежное мышление в безопасной среде.', href: '/blog/cashflow-almaty/', cta: 'Подробнее об игре' },
    { title: 'Стратегические выезды', when: 'Раз в квартал', text: 'Выездные сессии только для резидентов: глубокая проработка годовых целей и стратегии в кругу сильного окружения.', href: '/events/', cta: 'Расписание' },
];
---

<Layout
    title="О клубе BizPride — бизнес-клуб в Алматы"
    description="BizPride — открытое сообщество предпринимателей Алматы. Кто мы, какие форматы проводим, кому подходит клуб и как стать резидентом. Гостевой визит — бесплатно."
    keywords="о бизнес-клубе BizPride, что такое BizPride, бизнес-клуб Алматы о клубе, открытое сообщество предпринимателей Алматы, основатель BizPride"
    ogImage="/og/og-about.png"
>
    <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <!-- HERO -->
    <section class="about-hero" style="background-image: url('/img-about-hero-new.webp');">
        <div class="about-hero-overlay"></div>
        <div class="about-hero-content">
            <span class="about-eyebrow">Бизнес-клуб · Алматы</span>
            <h1 class="about-h1">О клубе <span class="red">BizPride</span></h1>
            <p class="about-lead">
                Открытое сообщество предпринимателей Алматы. Мы объединяем собственников бизнеса, чтобы правильное окружение кратно ускоряло рост каждого участника.
            </p>
        </div>
    </section>

    <!-- Breadcrumbs -->
    <section style="background: #0a0a0a; padding: 20px 24px; border-bottom: 1px solid rgba(255,255,255,0.08);">
        <div style="max-width: 1200px; margin: 0 auto;">
            <Breadcrumbs items={[
                { name: 'Главная', href: '/' },
                { name: 'О клубе' }
            ]} />
        </div>
    </section>

    <!-- MISSION -->
    <section style="background: #0a0a0a; padding: 80px 24px;">
        <div style="max-width: 820px; margin: 0 auto;">
            <h2 style="font-size: clamp(28px, 4vw, 40px); font-weight: 800; color: #fff; margin: 0 0 24px;">Зачем существует BizPride</h2>
            <p style="font-size: 18px; color: rgba(255,255,255,0.78); line-height: 1.75; margin-bottom: 20px;">
                Большинство предпринимателей растут в одиночку — на своих ошибках, без обратной связи от равных. BizPride создан, чтобы это изменить: дать собственникам бизнеса среду, где можно открыто разбирать реальные задачи, находить партнёров и принимать решения быстрее.
            </p>
            <p style="font-size: 18px; color: rgba(255,255,255,0.78); line-height: 1.75; margin-bottom: 36px;">
                Это не тренинги и не коворкинг. Это closed-сообщество действующих предпринимателей Алматы, которые помогают друг другу расти — через мастермайнды, нетворкинг и совместную работу над стратегией. Подробнее о формате — в статье <a href="/blog/chto-takoe-business-club/" style="color: var(--red); text-decoration: underline;">«Что такое бизнес-клуб»</a>.
            </p>
            <blockquote style="border-left: 4px solid var(--red, #c42b2b); padding: 4px 0 4px 24px; margin: 0; font-size: 22px; font-style: italic; color: #fff; line-height: 1.5;">
                «Вы — среднее арифметическое пяти человек, с которыми проводите больше всего времени. Выбирайте окружение осознанно.»
            </blockquote>
        </div>
    </section>

    <!-- STATS -->
    <section style="background: #111; padding: 60px 24px; border-top: 1px solid rgba(255,255,255,0.06); border-bottom: 1px solid rgba(255,255,255,0.06);">
        <div class="about-stats">
            {stats.map(s => (
                <div class="about-stat">
                    <div class="about-stat-value">{s.value}</div>
                    <div class="about-stat-label">{s.label}</div>
                </div>
            ))}
        </div>
    </section>

    <!-- FOUNDER -->
    <section style="background: #0a0a0a; padding: 80px 24px;">
        <div class="about-founder">
            <div class="about-founder-img">
                <Image src={founderImg} alt="Дмитрий Тимошевский — основатель бизнес-клуба BizPride" widths={[400, 700]} sizes="(max-width: 768px) 100vw, 420px" quality={82} loading="lazy" decoding="async" />
            </div>
            <div class="about-founder-text">
                <span class="about-eyebrow">Основатель</span>
                <h2 style="font-size: clamp(26px, 3.5vw, 36px); font-weight: 800; color: #fff; margin: 8px 0 20px;">Дмитрий Тимошевский</h2>
                <p style="font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: 18px;">
                    «Я создавал BizPride как клуб, в который сам хотел бы попасть: без воды и инфоцыганства, с конкретными разборами и людьми, у которых можно учиться на их реальном опыте.»
                </p>
                <p style="font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7;">
                    Сегодня клуб объединяет более 120 собственников бизнеса из разных сфер. Встречи проходят офлайн в Алматы на трёх языках — казахском, русском и английском.
                </p>
            </div>
        </div>
    </section>

    <!-- FORMATS -->
    <section style="background: #0d0d0f; padding: 80px 24px;">
        <div style="max-width: 1100px; margin: 0 auto;">
            <h2 style="font-size: clamp(28px, 4vw, 40px); font-weight: 800; color: #fff; margin: 0 0 12px; text-align: center;">Форматы встреч</h2>
            <p style="font-size: 17px; color: rgba(255,255,255,0.6); line-height: 1.6; text-align: center; max-width: 640px; margin: 0 auto 48px;">
                Регулярные офлайн-встречи в Алматы — от открытых бранчей для знакомства до закрытого совета директоров для резидентов.
            </p>
            <div class="about-formats">
                {formats.map(f => (
                    <div class="about-format-card">
                        <div class="about-format-when">{f.when}</div>
                        <h3 style="font-size: 20px; font-weight: 700; color: #fff; margin: 0 0 12px;">{f.title}</h3>
                        <p style="font-size: 15px; color: rgba(255,255,255,0.7); line-height: 1.6; flex-grow: 1; margin: 0 0 16px;">{f.text}</p>
                        <a href={f.href} style="color: var(--red); font-weight: 700; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; text-decoration: none;">{f.cta} &rarr;</a>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- IMAGE STRIP -->
    <section class="about-imgstrip">
        <div class="about-imgstrip-col">
            <Image src={mastermindImg} alt="Мастермайнд BizPride — закрытая встреча предпринимателей Алматы" widths={[400, 768]} sizes="(max-width: 768px) 100vw, 50vw" quality={80} loading="lazy" decoding="async" />
        </div>
        <div class="about-imgstrip-col">
            <Image src={networkingImg} alt="Нетворкинг на бизнес-бранче BizPride в Алматы" widths={[400, 768]} sizes="(max-width: 768px) 100vw, 50vw" quality={80} loading="lazy" decoding="async" />
        </div>
    </section>

    <!-- WHO IT'S FOR -->
    <section style="background: #0a0a0a; padding: 80px 24px;">
        <div style="max-width: 820px; margin: 0 auto;">
            <h2 style="font-size: clamp(28px, 4vw, 40px); font-weight: 800; color: #fff; margin: 0 0 24px;">Кому подходит клуб</h2>
            <p style="font-size: 18px; color: rgba(255,255,255,0.78); line-height: 1.75; margin-bottom: 20px;">
                BizPride — для собственников, топ-менеджеров и инвесторов с действующим бизнесом. Для членства мы ориентируемся на оборот от 50 млн ₸ в год, но смотрим в первую очередь на совпадение ценностей и реальный интерес расти через сообщество, а не на формальные показатели.
            </p>
            <p style="font-size: 18px; color: rgba(255,255,255,0.78); line-height: 1.75;">
                Каждый кандидат проходит знакомство с основателем — так мы сохраняем уровень и атмосферу клуба. Если вы только присматриваетесь к формату бизнес-клубов, начните с разбора <a href="/blog/chto-takoe-biznes-soobshchestvo/" style="color: var(--red); text-decoration: underline;">«клуб vs сообщество»</a> и <a href="/blog/luchshie-business-cluby-almaty/" style="color: var(--red); text-decoration: underline;">обзора лучших бизнес-клубов Алматы</a>.
            </p>
        </div>
    </section>

    <!-- CTA -->
    <section style="background: #0d0d0f; padding: 0 24px 100px;">
        <div style="max-width: 820px; margin: 0 auto; background: linear-gradient(135deg, rgba(196,43,43,0.15), rgba(196,43,43,0.05)); border: 1px solid rgba(196,43,43,0.3); border-radius: 20px; padding: 48px 36px; text-align: center;">
            <h2 style="font-size: 28px; font-weight: 800; color: #fff; margin: 0 0 16px;">Познакомьтесь с клубом изнутри</h2>
            <p style="font-size: 17px; color: rgba(255,255,255,0.85); margin-bottom: 28px;">Гостевой визит на субботний бизнес-бранч — бесплатно и без обязательств. Посмотрите формат, познакомьтесь с резидентами и решите, ваше это или нет.</p>
            <div style="display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;">
                <a href="/events/" style="display: inline-block; padding: 16px 36px; background: var(--red); color: #fff; text-decoration: none; font-weight: 700; font-size: 14px; letter-spacing: 1px; text-transform: uppercase; border-radius: 10px;">Расписание встреч</a>
                <a href="/pricing/" style="display: inline-block; padding: 16px 36px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: #fff; text-decoration: none; font-weight: 700; font-size: 14px; letter-spacing: 1px; text-transform: uppercase; border-radius: 10px;">Стоимость участия</a>
            </div>
        </div>
    </section>

    <BlogTeaser
        slugs={[
            'chto-takoe-business-club',
            'chto-takoe-mastermind',
            'rost-dohoda-cherez-okruzhenie'
        ]}
        heading="Глубже о форматах клуба"
        intro="Подробные материалы о формате бизнес-клубов, мастермайндах и о том, как окружение влияет на рост дохода предпринимателя."
    />
</Layout>

<style>
    .red { color: var(--red, #c42b2b); }

    .about-eyebrow {
        display: inline-block;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--red, #c42b2b);
    }

    /* HERO */
    .about-hero {
        position: relative;
        min-height: 52vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        padding: 120px 24px 60px;
    }
    .about-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(0,0,0,0.65), rgba(10,10,10,0.85));
    }
    .about-hero-content {
        position: relative;
        z-index: 2;
        max-width: 820px;
        text-align: center;
    }
    .about-h1 {
        font-size: clamp(40px, 7vw, 80px);
        font-weight: 900;
        line-height: 1.02;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: -2px;
        margin: 16px 0 20px;
    }
    .about-lead {
        font-size: clamp(16px, 2.2vw, 20px);
        color: rgba(255,255,255,0.82);
        line-height: 1.6;
        max-width: 680px;
        margin: 0 auto;
    }

    /* STATS */
    .about-stats {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }
    .about-stat { text-align: center; }
    .about-stat-value {
        font-size: clamp(32px, 5vw, 52px);
        font-weight: 900;
        color: var(--red, #c42b2b);
        line-height: 1;
    }
    .about-stat-label {
        margin-top: 10px;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: rgba(255,255,255,0.6);
    }
    @media (max-width: 700px) {
        .about-stats { grid-template-columns: repeat(2, 1fr); gap: 32px 16px; }
    }

    /* FOUNDER */
    .about-founder {
        max-width: 1000px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 420px 1fr;
        gap: 48px;
        align-items: center;
    }
    .about-founder-img :global(img) {
        width: 100%;
        height: auto;
        border-radius: 16px;
        display: block;
        filter: grayscale(15%);
    }
    @media (max-width: 768px) {
        .about-founder { grid-template-columns: 1fr; gap: 28px; }
        .about-founder-img { max-width: 360px; }
    }

    /* FORMATS */
    .about-formats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
    }
    .about-format-card {
        background: #161922;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        padding: 28px 24px;
        display: flex;
        flex-direction: column;
        transition: border-color 0.3s, transform 0.3s;
    }
    .about-format-card:hover {
        border-color: var(--red, #c42b2b);
        transform: translateY(-4px);
    }
    .about-format-when {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: rgba(255,255,255,0.45);
        margin-bottom: 12px;
    }

    /* IMAGE STRIP */
    .about-imgstrip {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2px;
        background: #1a1a1a;
    }
    .about-imgstrip-col :global(img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        filter: grayscale(60%);
        transition: filter 0.4s;
    }
    .about-imgstrip-col:hover :global(img) { filter: grayscale(0%); }
    @media (max-width: 600px) {
        .about-imgstrip { grid-template-columns: 1fr; }
    }
</style>

---
import Layout from '../layouts/Layout.astro';

// SEO Hub for BizPride Club Blog - Editorial Redesign
---

<Layout 
    title="Блог бизнес-клуба BizPride Алматы | База знаний для предпринимателей"
    description="Все о закрытых бизнес-клубах, мастермайндах и нетворкинге в Алматы. Читайте опыт резидентов и аналитику рынка в блоге BizPride Club."
>
    <div class="editorial-container">
        
        <!-- ROW 1: INTRO (Full Width Parallax) -->
        <section class="ed-row height-vh hero-parallax-section" style="background-image: url('/img-about-hero-new.jpg');">
            <div class="hero-overlay"></div>
            <div class="ed-col text-col content-center" style="position: relative; z-index: 2; width: 100%; text-align: center; display: flex; align-items: center; justify-content: center;">
                <div class="ed-content" style="max-width: 800px; margin: 0 auto; padding: 20px;">
                    <h1 class="ed-title" style="margin-bottom: 20px;">БЛОГ<br><span class="ed-accent">О КЛУБЕ</span></h1>
                    <p class="ed-desc" style="font-size: 20px; line-height: 1.6; color: #f0f0f0;">
                        Погрузитесь в экосистему закрытого сообщества. Здесь мы делимся практическим опытом, аналитикой рынка и рассказываем, как правильное окружение кратно увеличивает масштаб бизнеса.
                    </p>
                </div>
            </div>
        </section>

        <!-- NAV ROW: TABS -->
        <section class="ed-nav-row">
            <div class="ed-nav-container">
                <a href="#all" class="ed-nav-btn active">ВСЕ ТЕМЫ</a>
                <a href="#sales" class="ed-nav-btn">ПРОДАЖИ И ПЕРЕГОВОРЫ</a>
                <a href="#management" class="ed-nav-btn">УПРАВЛЕНИЕ И КОМАНДА</a>
                <a href="#marketing" class="ed-nav-btn">МАРКЕТИНГ И ПРОДВИЖЕНИЕ</a>
                <a href="#mindset" class="ed-nav-btn">МЫШЛЕНИЕ И РАЗВИТИЕ</a>
                <a href="#community" class="ed-nav-btn">МЕРОПРИЯТИЯ КЛУБА</a>
            </div>
        </section>

        <!-- BLOG GRID -->
        <section class="ed-blog-grid-section">
            <div class="ed-blog-container">
                <div class="ed-blog-grid">
                    
                    <!-- Article Card 1 -->
                    <a href="/blog/chto-takoe-business-club" class="ed-card">
                        <div class="ed-card-img" style="background-image: url('/img-mastermind.png');"></div>
                        <div class="ed-card-content">
                            <span class="ed-card-tag">УПРАВЛЕНИЕ И КОМАНДА</span>
                            <h3 class="ed-card-title">Что такое бизнес-клуб и зачем он нужен предпринимателю?</h3>
                            <span class="ed-card-link">Читать статью &rarr;</span>
                        </div>
                    </a>

                    <!-- Article Card 2 -->
                    <a href="#" class="ed-card">
                        <div class="ed-card-img" style="background-image: url('/img-networking.png');"></div>
                        <div class="ed-card-content">
                            <span class="ed-card-tag">МЕРОПРИЯТИЯ КЛУБА</span>
                            <h3 class="ed-card-title">Нетворкинг: как правильное окружение кратно растит доход</h3>
                            <span class="ed-card-link">Читать статью &rarr;</span>
                        </div>
                    </a>

                    <!-- Video Card 1 -->
                    <a href="https://www.youtube.com/watch?v=i8DyxfJR9G8" target="_blank" class="ed-card video-card">
                        <div class="ed-card-img" style="background-image: url('https://img.youtube.com/vi/i8DyxfJR9G8/maxresdefault.jpg');">
                            <div class="video-play-icon">&#9658;</div>
                        </div>
                        <div class="ed-card-content">
                            <span class="ed-card-tag">ПРОДАЖИ И ПЕРЕГОВОРЫ</span>
                            <h3 class="ed-card-title">Клиент сказал "ДОРОГО" и пропал. Смотри, что я написал и он ответил</h3>
                            <span class="ed-card-link">Смотреть видео &rarr;</span>
                        </div>
                    </a>

                </div>
            </div>
        </section>

        <!-- ROW 2: ABOUT / FORMATS -->
        <section class="ed-row height-auto reverse-mobile">
            <div class="ed-col text-col content-center bg-darker">
                <div class="ed-content">
                    <h2 class="ed-subtitle">ЧТО ТАКОЕ БИЗНЕС-КЛУБ?</h2>
                    <p class="ed-desc">
                        Главная якорная статья. Отличия от коворкингов, тренингов и реальные преимущества закрытого сообщества. Глубокий разбор форматов закрытых сообществ и их влияния на развитие компаний.
                    </p>
                    <a href="/blog/chto-takoe-business-club" class="ed-link">ЧИТАТЬ СТАТЬЮ &rarr;</a>
                </div>
            </div>
            <div class="ed-col image-col">
                <img src="/img-mastermind.png" alt="Мастермайнд" class="ed-img grayscale" />
            </div>
        </section>

        <!-- ROW 4: SERVICES/TRAFFIC -->
        <section class="ed-row height-auto">
            <div class="ed-col text-col content-center">
                <div class="ed-content">
                    <h2 class="ed-subtitle">БИЗНЕС-ВСТРЕЧИ В АЛМАТЫ</h2>
                    <div class="ed-services">
                        <div class="ed-service">
                            <h3>БИЗНЕС-БРАНЧ</h3>
                            <p>Открытый формат делового общения и нетворкинга за завтраком. Проходит каждую субботу для всех желающих.</p>
                            <a href="/blog/business-meropriyatiya-almaty-2026" class="ed-link">ПОДРОБНЕЕ &rarr;</a>
                        </div>
                        <div class="ed-service">
                            <h3>СОВЕТ ДИРЕКТОРОВ</h3>
                            <p>Глубокая проработка бизнес-процессов только для резидентов. Проходит каждый вторник в закрытом формате.</p>
                            <a href="/events" class="ed-link">РАСПИСАНИЕ &rarr;</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="ed-col image-col">
                <img src="/img-networking.png" alt="Нетворкинг" class="ed-img grayscale" />
            </div>
        </section>
    </div>
</Layout>

<style>
    /* Reset & Base within this layout */
    .editorial-container {
        background: #0a0a0a;
        color: #fff;
        font-family: var(--font, 'Montserrat', sans-serif);
        padding-top: 80px; /* Offset for nav */
    }

    .ed-row {
        display: flex;
        flex-direction: column;
        width: 100%;
        border-bottom: 2px solid #1a1a1a;
    }

    @media (min-width: 768px) {
        .ed-row {
            flex-direction: row;
        }
        .ed-row > .ed-col {
            flex: 1;
            width: 50%;
            border-right: 2px solid #1a1a1a;
        }
        .ed-row > .ed-col:last-child {
            border-right: none;
        }
    }

    .height-vh {
        min-height: 35vh; /* Reduced height by ~3x */
    }

    .height-auto {
        min-height: 500px;
    }

    /* BLOG GRID */
    .ed-blog-grid-section {
        padding: 80px 20px;
        background: #ffffff; /* White background */
        border-bottom: 2px solid #eaeaea;
    }

    .ed-blog-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .ed-blog-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 30px;
    }

    .ed-card {
        display: flex;
        flex-direction: column;
        background: #ffffff;
        border: 1px solid #eaeaea;
        border-radius: 12px;
        overflow: hidden;
        text-decoration: none;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05); /* Soft shadow for depth */
        transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }

    .ed-card:hover {
        transform: translateY(-5px);
        border-color: var(--brand, #c42b2b);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .ed-card-img {
        width: 100%;
        height: 220px;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        filter: grayscale(100%) brightness(0.8);
        transition: filter 0.3s ease;
        position: relative;
    }

    .ed-card:hover .ed-card-img {
        filter: grayscale(0%) brightness(1);
    }

    .video-play-icon {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 40px;
        color: rgba(255,255,255,0.8);
        transition: color 0.3s ease;
    }

    .ed-card:hover .video-play-icon {
        color: var(--brand, #c42b2b);
    }

    .ed-card-content {
        padding: 25px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .ed-card-tag {
        font-size: 11px;
        font-weight: 700;
        color: var(--brand, #c42b2b);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 15px;
    }

    .ed-card-title {
        font-size: 18px;
        color: #111111; /* Dark text for light card */
        line-height: 1.4;
        margin-bottom: 20px;
        font-weight: 700;
        flex-grow: 1;
    }

    .ed-card-link {
        font-size: 13px;
        color: #666666; /* Darker gray for readability on white */
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: color 0.3s ease;
    }

    .ed-card:hover .ed-card-link {
        color: var(--brand, #c42b2b); /* Highlight red on hover instead of white */
    }

    .ed-nav-row {
        width: 100%;
        background: #0a0a0a; /* or #111 depending on preference */
        border-bottom: 2px solid #1a1a1a;
        padding: 30px 0;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .ed-nav-container {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
        padding: 0 20px;
        justify-content: center;
    }

    .ed-nav-btn {
        background: transparent;
        color: rgba(255, 255, 255, 0.7);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 12px 24px;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        text-decoration: none;
        border-radius: 30px; /* Pill shape */
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    .ed-nav-btn:hover {
        border-color: #fff;
        color: #fff;
        transform: translateY(-3px); /* Lift animation on hover */
        box-shadow: 0 4px 15px rgba(255, 255, 255, 0.1);
    }

    .ed-nav-btn.active {
        background: var(--brand, #c42b2b);
        border-color: var(--brand, #c42b2b);
        color: #fff;
    }

    .ed-nav-btn.active:hover {
        box-shadow: 0 4px 15px rgba(196, 43, 43, 0.4); /* Brand color glow */
    }

    @media (max-width: 767px) {
        .ed-nav-btn {
            width: 100%;
            text-align: center;
        }
    }

    .image-col {
        position: relative;
        overflow: hidden;
        min-height: 300px; /* for mobile */
        background: #111;
        padding: 40px; /* Internal padding for photos in the editorial layout */
        display: flex;
        align-items: center;
        justify-content: center;
    }

    @media (max-width: 767px) {
        .image-col {
            padding: 20px;
        }
    }

    /* For the hero image, we might want it edge-to-edge */
    .height-vh .image-col {
        padding: 0; 
    }

    .ed-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
    
    .hero-parallax-section {
        position: relative;
        background-attachment: fixed;
        background-position: center;
        background-repeat: no-repeat;
        background-size: cover;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .hero-parallax-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.7); /* Dark overlay to make text readable */
        z-index: 1;
        transition: background 0.5s ease;
    }

    .hero-parallax-section:hover::before {
        background: rgba(0, 0, 0, 0.5); /* Slightly lighter on hold/hover for effect */
    }

    .text-col {
        padding: 40px;
        display: flex;
        flex-direction: column;
    }

    @media (min-width: 1024px) {
        .text-col {
            padding: 60px 80px;
        }
    }

    .content-center {
        justify-content: center;
    }

    .bg-darker {
        background: #111;
    }

    .ed-title {
        font-size: clamp(48px, 6vw, 84px);
        font-weight: 900;
        line-height: 1;
        margin-bottom: 30px;
        text-transform: uppercase;
        letter-spacing: -2px;
    }

    .ed-accent {
        color: var(--brand, #c42b2b);
    }

    .ed-subtitle {
        font-size: clamp(32px, 4vw, 56px);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 30px;
        text-transform: uppercase;
        letter-spacing: -1px;
    }

    .ed-desc {
        font-size: 16px;
        color: rgba(255, 255, 255, 0.7);
        line-height: 1.6;
        max-width: 500px;
        margin-bottom: 20px;
    }

    .ed-link {
        display: inline-block;
        margin-top: 10px;
        color: var(--brand, #c42b2b);
        text-decoration: none;
        font-weight: 700;
        font-size: 13px;
        letter-spacing: 2px;
        text-transform: uppercase;
        transition: color 0.3s;
    }

    .ed-link:hover {
        color: #fff;
    }

    .ed-list {
        display: flex;
        flex-direction: column;
        gap: 25px;
        margin-top: 20px;
    }

    .ed-list-item {
        display: flex;
        align-items: flex-start;
        gap: 20px;
    }

    .ed-number {
        font-size: 20px;
        font-weight: 300;
        color: rgba(255, 255, 255, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .ed-list-text p {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.5;
        margin: 0;
        max-width: 300px;
    }

    .ed-list-text strong {
        color: #fff;
        display: block;
        margin-bottom: 4px;
        font-size: 15px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .ed-services {
        display: grid;
        grid-template-columns: 1fr;
        gap: 40px;
        margin-top: 30px;
    }

    @media (min-width: 1200px) {
        .ed-services {
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
    }

    .ed-service h3 {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 12px;
        color: #fff;
        text-transform: uppercase;
    }

    .ed-service p {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.5;
        margin-bottom: 10px;
    }

    /* Reverse order on mobile for some rows to keep text->image flow */
    @media (max-width: 767px) {
        .reverse-mobile {
            flex-direction: column-reverse;
        }
    }
</style>

---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://bizpride.kz/" },
        { "@type": "ListItem", "position": 2, "name": "Бизнес-бранч", "item": "https://bizpride.kz/business-brunch/" }
    ]
};

// Recurring Event schema — next Saturday brunch. Google shows this
// in SERP as a rich "Event" result with date, location, price.
const now = new Date();
const daysUntilSaturday = (6 - now.getDay() + 7) % 7 || 7;
const nextSaturday = new Date(now.getTime() + daysUntilSaturday * 86400000);
const saturdayISO = nextSaturday.toISOString().split('T')[0];

const eventSchema = {
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Бизнес-бранч BizPride — еженедельная встреча предпринимателей",
    "description": "Открытый бизнес-бранч для предпринимателей Алматы: спикер на актуальную тему + speed-dating + нетворкинг. Разовое посещение — 10 000 ₸.",
    "startDate": `${saturdayISO}T11:00:00+05:00`,
    "endDate": `${saturdayISO}T14:00:00+05:00`,
    "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
    "eventStatus": "https://schema.org/EventScheduled",
    "eventSchedule": {
        "@type": "Schedule",
        "repeatFrequency": "P1W",
        "byDay": "https://schema.org/Saturday",
        "startTime": "11:00:00+05:00",
        "endTime": "14:00:00+05:00"
    },
    "image": "https://bizpride.kz/img-mastermind.png",
    "performer": { "@id": "https://bizpride.kz/#organization" },
    "organizer": { "@id": "https://bizpride.kz/#organization" },
    "location": {
        "@type": "Place",
        "name": "Премиальный ресторан Алматы (адрес по записи)",
        "address": {
            "@type": "PostalAddress",
            "addressLocality": "Алматы",
            "addressCountry": "KZ"
        }
    },
    "offers": {
        "@type": "Offer",
        "url": "https://wa.me/77070357777",
        "price": "10000",
        "priceCurrency": "KZT",
        "availability": "https://schema.org/InStock",
        "description": "Разовое посещение — 10 000 ₸"
    }
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        { "@type": "Question", "name": "Сколько стоит бизнес-бранч BizPride?", "acceptedAnswer": { "@type": "Answer", "text": "Разовое посещение — 10 000 ₸. Для резидентов клуба все субботние бранчи входят в годовое членство." } },
        { "@type": "Question", "name": "Когда проходят бизнес-бранчи?", "acceptedAnswer": { "@type": "Answer", "text": "Каждую субботу с 11:00 до 14:00 в премиальных ресторанах Алматы. Конкретный адрес сообщается после записи." } },
        { "@type": "Question", "name": "Кто может прийти на бизнес-бранч?", "acceptedAnswer": { "@type": "Answer", "text": "Действующие предприниматели, собственники бизнеса, топ-менеджеры — на первый визит в статусе гостя без обязательств. После гостевого визита решаем о резидентстве." } },
        { "@type": "Question", "name": "Что взять с собой на бизнес-бранч?", "acceptedAnswer": { "@type": "Answer", "text": "Только себя и телефон (Telegram для обмена контактами). Блокнот/ноутбук — если хотите записывать за спикером. Визитки необязательны — все контакты обмениваются через Telegram." } }
    ]
};
---

<Layout
    title="Бизнес-бранч BizPride — субботние встречи в Алматы"
    description="Бизнес-бранч каждую субботу в Алматы: спикер, speed-dating, 30-70 предпринимателей. Разовое посещение — 10 000 ₸. Расписание и запись."
>
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

    <section style="padding: 110px 24px 24px; max-width: 1200px; margin: 0 auto;">
        <Breadcrumbs items={[
            { name: 'Главная', href: '/' },
            { name: 'Бизнес-бранч' }
        ]} />
    </section>

    <section style="max-width: 1200px; margin: 0 auto; padding: 24px 24px 60px;">
        <div style="max-width: 760px;">
            <span style="display: inline-block; background: rgba(196,43,43,0.12); border: 1px solid rgba(196,43,43,0.3); padding: 8px 16px; border-radius: 999px; font-size: 12px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #fff; margin-bottom: 24px;">🍳 Каждую субботу</span>
            <h1 style="font-size: clamp(36px, 5vw, 56px); font-weight: 900; color: #fff; line-height: 1.1; margin: 0 0 20px;">Бизнес-бранч BizPride<br>в Алматы</h1>
            <p style="font-size: 18px; color: rgba(255,255,255,0.75); line-height: 1.6;">
                Основной формат знакомства с клубом. Каждую субботу 30-70 предпринимателей Алматы завтракают вместе в премиальном ресторане: один спикер на актуальную тему + speed-dating + свободный нетворкинг. Разовое посещение — 10 000 ₸, для резидентов входит в членство.
            </p>
        </div>
    </section>

    <!-- Stats -->
    <section style="background: var(--bg-secondary, #111); padding: 60px 24px; border-top: 1px solid rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.05);">
        <div style="max-width: 1200px; margin: 0 auto;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 32px;">
                <div><div style="font-size: 40px; font-weight: 900; color: var(--red); margin-bottom: 8px;">30-70</div><div style="font-size: 16px; color: rgba(255,255,255,0.85); font-weight: 600;">предпринимателей</div><div style="font-size: 14px; color: rgba(255,255,255,0.5); margin-top: 6px;">на каждом бранче</div></div>
                <div><div style="font-size: 40px; font-weight: 900; color: var(--red); margin-bottom: 8px;">3 часа</div><div style="font-size: 16px; color: rgba(255,255,255,0.85); font-weight: 600;">суббота 11:00-14:00</div><div style="font-size: 14px; color: rgba(255,255,255,0.5); margin-top: 6px;">спикер + нетворкинг + обед</div></div>
                <div><div style="font-size: 40px; font-weight: 900; color: var(--red); margin-bottom: 8px;">4K</div><div style="font-size: 16px; color: rgba(255,255,255,0.85); font-weight: 600;">камеры продакшн</div><div style="font-size: 14px; color: rgba(255,255,255,0.5); margin-top: 6px;">фото + видео для соцсетей</div></div>
                <div><div style="font-size: 40px; font-weight: 900; color: var(--red); margin-bottom: 8px;">10 000 ₸</div><div style="font-size: 16px; color: rgba(255,255,255,0.85); font-weight: 600;">разовый визит</div><div style="font-size: 14px; color: rgba(255,255,255,0.5); margin-top: 6px;">для резидентов — в членстве</div></div>
            </div>
        </div>
    </section>

    <!-- Format -->
    <section style="max-width: 800px; margin: 0 auto; padding: 80px 24px;">
        <h2 style="font-size: clamp(28px, 4vw, 40px); font-weight: 800; color: #fff; margin: 0 0 24px;">Как проходит бранч</h2>
        <p style="font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: 32px;">Чёткий тайминг: каждый бранч — 3 часа с 4 блоками. Вы точно знаете, что произойдёт и когда.</p>
        <div style="display: flex; flex-direction: column; gap: 0;">
            <div style="display: grid; grid-template-columns: 70px 1fr; gap: 20px; padding: 24px 0; border-bottom: 1px solid rgba(255,255,255,0.08);">
                <div style="font-size: 14px; font-weight: 700; color: var(--red);">11:00</div>
                <div><h3 style="margin: 0 0 6px; color: #fff; font-size: 18px;">Кофе и знакомства</h3><p style="margin: 0; color: rgba(255,255,255,0.75);">Приходите, берёте кофе, знакомитесь с теми, кто рядом. Модератор помогает «сломать лёд» — нет ситуации «стою у стены один».</p></div>
            </div>
            <div style="display: grid; grid-template-columns: 70px 1fr; gap: 20px; padding: 24px 0; border-bottom: 1px solid rgba(255,255,255,0.08);">
                <div style="font-size: 14px; font-weight: 700; color: var(--red);">11:30</div>
                <div><h3 style="margin: 0 0 6px; color: #fff; font-size: 18px;">Спикер (30-40 мин + Q&A)</h3><p style="margin: 0; color: rgba(255,255,255,0.75);">Действующий предприниматель или эксперт-практик. Темы: продажи, управление, маркетинг, финансы, лидерство. Полный список прошлых выступлений — в <a href="/blog/" style="color: var(--red); text-decoration: underline;">блоге</a>.</p></div>
            </div>
            <div style="display: grid; grid-template-columns: 70px 1fr; gap: 20px; padding: 24px 0; border-bottom: 1px solid rgba(255,255,255,0.08);">
                <div style="font-size: 14px; font-weight: 700; color: var(--red);">12:10</div>
                <div><h3 style="margin: 0 0 6px; color: #fff; font-size: 18px;">Speed-dating (30 мин)</h3><p style="margin: 0; color: rgba(255,255,255,0.75);">Структурированный нетворкинг: 3 минуты на знакомство с каждым → сигнал → переход. За 30 минут вы поговорите с 8-10 людьми.</p></div>
            </div>
            <div style="display: grid; grid-template-columns: 70px 1fr; gap: 20px; padding: 24px 0;">
                <div style="font-size: 14px; font-weight: 700; color: var(--red);">12:40</div>
                <div><h3 style="margin: 0 0 6px; color: #fff; font-size: 18px;">Свободный нетворкинг + обед</h3><p style="margin: 0; color: rgba(255,255,255,0.75);">Обедаете вместе, углубляете знакомства 1-на-1. Самая ценная часть — неформальные разговоры за столом.</p></div>
            </div>
        </div>
    </section>

    <!-- Difference from other events -->
    <section style="background: var(--bg-secondary, #111); padding: 80px 24px;">
        <div style="max-width: 800px; margin: 0 auto;">
            <h2 style="font-size: clamp(28px, 4vw, 36px); font-weight: 800; color: #fff; margin: 0 0 24px;">Чем бранч BizPride отличается от обычных бизнес-ивентов</h2>
            <table style="width: 100%; border-collapse: collapse; margin: 0 0 24px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; overflow: hidden;">
                <thead>
                    <tr style="background: rgba(196,43,43,0.15);">
                        <th style="padding: 14px 16px; text-align: left; color: #fff; font-weight: 700;">Обычный бизнес-ивент</th>
                        <th style="padding: 14px 16px; text-align: left; color: #fff; font-weight: 700;">Бранч BizPride</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td style="padding: 12px 16px; color: rgba(255,255,255,0.7); border-top: 1px solid rgba(255,255,255,0.05);">Случайная аудитория, много «продавцов»</td><td style="padding: 12px 16px; color: rgba(255,255,255,0.85); border-top: 1px solid rgba(255,255,255,0.05);">Фильтрованная: только собственники МСБ</td></tr>
                    <tr><td style="padding: 12px 16px; color: rgba(255,255,255,0.7); border-top: 1px solid rgba(255,255,255,0.05);">Нет структуры нетворкинга</td><td style="padding: 12px 16px; color: rgba(255,255,255,0.85); border-top: 1px solid rgba(255,255,255,0.05);">Speed-dating: 8-10 целевых знакомств</td></tr>
                    <tr><td style="padding: 12px 16px; color: rgba(255,255,255,0.7); border-top: 1px solid rgba(255,255,255,0.05);">Разовое — после ивента забыли</td><td style="padding: 12px 16px; color: rgba(255,255,255,0.85); border-top: 1px solid rgba(255,255,255,0.05);">Еженедельное — связи углубляются</td></tr>
                    <tr><td style="padding: 12px 16px; color: rgba(255,255,255,0.7);">Нет продакшна</td><td style="padding: 12px 16px; color: rgba(255,255,255,0.85);">4 камеры + фотограф → контент бесплатно</td></tr>
                </tbody>
            </table>
            <p style="font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7;">
                После бранча — если формат зашёл — следующий шаг: <a href="/mastermind/" style="color: var(--red); text-decoration: underline;">мастермайнды по вторникам</a> (закрытый формат для резидентов). Подробнее о том, <a href="/business-club/" style="color: var(--red); text-decoration: underline;">что такое бизнес-клуб BizPride</a> и <a href="/pricing/" style="color: var(--red); text-decoration: underline;">сколько стоит членство</a>.
            </p>
        </div>
    </section>

    <!-- FAQ -->
    <section style="max-width: 800px; margin: 0 auto; padding: 80px 24px;">
        <h2 style="font-size: clamp(28px, 4vw, 36px); font-weight: 800; color: #fff; margin: 0 0 32px;">Частые вопросы про бранч</h2>
        <div style="display: flex; flex-direction: column; gap: 14px;">
            {faqSchema.mainEntity.map((q: any) => (
                <details style="background: var(--bg-card, #161922); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 22px 24px;">
                    <summary style="cursor: pointer; font-size: 17px; font-weight: 700; color: #fff; list-style: none; position: relative; padding-right: 32px;">
                        {q.name}
                        <span style="position: absolute; right: 0; top: 50%; transform: translateY(-50%); color: var(--red); font-size: 22px;">+</span>
                    </summary>
                    <p style="margin: 16px 0 0; color: rgba(255,255,255,0.78); font-size: 15px; line-height: 1.7;">{q.acceptedAnswer.text}</p>
                </details>
            ))}
        </div>
    </section>

    <!-- CTA -->
    <section style="max-width: 800px; margin: 0 auto; padding: 0 24px 100px;">
        <div style="background: linear-gradient(135deg, rgba(196,43,43,0.15), rgba(196,43,43,0.05)); border: 1px solid rgba(196,43,43,0.3); border-radius: 20px; padding: 48px 36px; text-align: center;">
            <h2 style="font-size: 26px; font-weight: 800; color: #fff; margin: 0 0 16px;">Записаться на ближайший бранч</h2>
            <p style="font-size: 17px; color: rgba(255,255,255,0.85); margin-bottom: 28px;">Напишите в WhatsApp — мы пришлём дату, адрес и тему спикера. Разовое посещение — 10 000 ₸.</p>
            <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
                <a href="https://wa.me/77070357777?text=%D0%97%D0%B4%D1%80%D0%B0%D0%B2%D1%81%D1%82%D0%B2%D1%83%D0%B9%D1%82%D0%B5!%20%D0%A5%D0%BE%D1%87%D1%83%20%D0%BD%D0%B0%20%D0%B1%D0%B8%D0%B7%D0%BD%D0%B5%D1%81-%D0%B1%D1%80%D0%B0%D0%BD%D1%87%20BizPride" target="_blank" rel="noopener" style="display: inline-block; padding: 16px 32px; background: var(--red); color: #fff; text-decoration: none; font-weight: 700; font-size: 14px; letter-spacing: 1px; text-transform: uppercase; border-radius: 10px;">Записаться в WhatsApp</a>
                <a href="/events/" style="display: inline-block; padding: 16px 32px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15); color: #fff; text-decoration: none; font-weight: 700; font-size: 14px; letter-spacing: 1px; text-transform: uppercase; border-radius: 10px;">Расписание →</a>
            </div>
        </div>
    </section>
</Layout>

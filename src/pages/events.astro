---
import Layout from '../layouts/Layout.astro';
import BlogTeaser from '../components/BlogTeaser.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import audienceImg from '../assets/img-audience.webp';
import { client, urlFor } from '../lib/sanity';

const albums = await client.fetch(`*[_type == "photoAlbum"] | order(order asc, _createdAt desc)`);

// ═══ DYNAMIC CALENDAR GENERATION ═══
const MONTH_NAMES = ['ЯНВАРЬ','ФЕВРАЛЬ','МАРТ','АПРЕЛЬ','МАЙ','ИЮНЬ','ИЮЛЬ','АВГУСТ','СЕНТЯБРЬ','ОКТЯБРЬ','НОЯБРЬ','ДЕКАБРЬ'];

const now = new Date();
const currentMonth = now.getMonth();  // 0-indexed
const currentYear = now.getFullYear();

const month1 = { month: currentMonth, year: currentYear };
const month2 = { 
    month: currentMonth === 11 ? 0 : currentMonth + 1, 
    year:  currentMonth === 11 ? currentYear + 1 : currentYear 
};

function getDaysInMonth(year: number, month: number) {
    return new Date(year, month + 1, 0).getDate();
}

function getFirstDayOfWeek(year: number, month: number) {
    // 0=Mon, 1=Tue ... 6=Sun (ISO week)
    const d = new Date(year, month, 1).getDay();
    return d === 0 ? 6 : d - 1;
}

function getWeekOfMonth(day: number, firstDow: number) {
    // Week number within the month (1-based)
    return Math.ceil((day + firstDow) / 7);
}

interface CalEvent {
    title: string;
    time?: string;
    description: string;
}

function getEventsForDay(year: number, month: number, day: number): CalEvent[] {
    const date = new Date(year, month, day);
    const dow = date.getDay(); // 0=Sun, 1=Mon, ... 6=Sat
    const firstDow = getFirstDayOfWeek(year, month);
    const weekNum = getWeekOfMonth(day, firstDow);
    const events: CalEvent[] = [];

    // Tuesday (dow=2) → СОВЕТ ДИРЕКТОРОВ
    if (dow === 2) {
        events.push({
            title: 'СОВЕТ ДИРЕКТОРОВ',
            time: '09:00 — 13:00',
            description: 'Глубокий разбор бизнес-кейсов.'
        });
    }

    // Thursday (dow=4) 2nd & 4th week → Трекинг
    if (dow === 4 && (weekNum === 2 || weekNum === 4)) {
        events.push({
            title: 'ТРЕКИНГ',
            time: '08:00 — 12:00',
            description: 'Трекинговая сессия для резидентов.'
        });
    }

    // Saturday (dow=6) → Бизнес-Бранч или Family Day
    if (dow === 6) {
        if (weekNum === 1) {
            events.push({
                title: 'FAMILY DAY',
                time: '08:00 — 17:00',
                description: 'Семейный день резидентов.'
            });
        } else {
            events.push({
                title: 'БИЗНЕС-БРАНЧ',
                time: '12:00 — 15:00',
                description: 'Деловое общение за завтраком.'
            });
        }
    }

    // Sunday (dow=0) → CASHFLOW
    if (dow === 0) {
        events.push({
            title: 'CASHFLOW',
            time: '17:00 — 20:30',
            description: 'Финансовая игра.'
        });
    }

    return events;
}

interface CalDay {
    day: number;
    empty: boolean;
    events: CalEvent[];
}

function generateMonthGrid(year: number, month: number): CalDay[] {
    const daysInMonth = getDaysInMonth(year, month);
    const firstDow = getFirstDayOfWeek(year, month);
    const grid: CalDay[] = [];

    // Leading empty cells (prev month)
    for (let i = 0; i < firstDow; i++) {
        grid.push({ day: 0, empty: true, events: [] });
    }

    // Actual days
    for (let d = 1; d <= daysInMonth; d++) {
        grid.push({ day: d, empty: false, events: getEventsForDay(year, month, d) });
    }

    // Trailing empty cells to fill last row
    const remainder = grid.length % 7;
    if (remainder > 0) {
        for (let i = 0; i < (7 - remainder); i++) {
            grid.push({ day: 0, empty: true, events: [] });
        }
    }

    return grid;
}

const grid1 = generateMonthGrid(month1.year, month1.month);
const grid2 = generateMonthGrid(month2.year, month2.month);
const name1 = MONTH_NAMES[month1.month];
const name2 = MONTH_NAMES[month2.month];

// Schema.org events for first Sunday of current month
const firstSunday = (() => {
    for (let d = 1; d <= getDaysInMonth(month1.year, month1.month); d++) {
        if (new Date(month1.year, month1.month, d).getDay() === 0) return d;
    }
    return 7;
})();
const schemaDate = `${month1.year}-${String(month1.month + 1).padStart(2, '0')}-${String(firstSunday).padStart(2, '0')}`;
---

<Layout
    title="Мероприятия BizPride — расписание бранчей в Алматы"
    description="Календарь бизнес-бранчей, мастермайндов и встреч клуба BizPride в Алматы. Гостевой визит — бесплатно."
    navTheme="dark"
>
    <section class="section-light" id="calendar">
        <div class="container container-large" style="padding-top: 100px; padding-bottom: 16px;">
            <Breadcrumbs items={[
                { name: 'Главная', href: '/' },
                { name: 'Мероприятия' }
            ]} theme="light" />
        </div>
        <div class="container container-large">
            <div class="calendar-header-wrapper">
                <h1 class="calendar-title reveal">РАСПИСАНИЕ <span class="calendar-title-small">МЕРОПРИЯТИЙ</span></h1>
            </div>

            <div class="cal-dual-wrapper">
                {/* ═══ MONTH 1 ═══ */}
                <div class="cal-month-block reveal reveal-d1">
                    <h2 class="cal-month-name">{name1}</h2>
                    <div class="cal-mini-wrapper">
                        <div class="cal-mini-header-row">
                            <div class="cal-mini-h">Пн</div>
                            <div class="cal-mini-h">Вт</div>
                            <div class="cal-mini-h">Ср</div>
                            <div class="cal-mini-h">Чт</div>
                            <div class="cal-mini-h">Пт</div>
                            <div class="cal-mini-h">Сб</div>
                            <div class="cal-mini-h">Вс</div>
                        </div>
                        <div class="cal-mini-grid">
                            {grid1.map(cell => (
                                cell.empty ? (
                                    <div class="cal-mini-day empty"></div>
                                ) : cell.events.length > 0 ? (
                                    <div class="cal-mini-day has-event">
                                        {cell.day}
                                        <div class="cal-popup">
                                            {cell.events.map(ev => (
                                                <div class="cal-popup-event">
                                                    <strong>{ev.title}</strong>
                                                    {ev.time && <span class="cal-popup-time">{ev.time}</span>}
                                                    <p>{ev.description}</p>
                                                </div>
                                            ))}
                                            <a href="https://wa.me/77070357777" class="cal-btn-wa" target="_blank">Принять участие</a>
                                        </div>
                                    </div>
                                ) : (
                                    <div class="cal-mini-day">{cell.day}</div>
                                )
                            ))}
                        </div>
                    </div>
                </div>

                {/* ═══ MONTH 2 ═══ */}
                <div class="cal-month-block reveal reveal-d2">
                    <h2 class="cal-month-name">{name2}</h2>
                    <div class="cal-mini-wrapper">
                        <div class="cal-mini-header-row">
                            <div class="cal-mini-h">Пн</div>
                            <div class="cal-mini-h">Вт</div>
                            <div class="cal-mini-h">Ср</div>
                            <div class="cal-mini-h">Чт</div>
                            <div class="cal-mini-h">Пт</div>
                            <div class="cal-mini-h">Сб</div>
                            <div class="cal-mini-h">Вс</div>
                        </div>
                        <div class="cal-mini-grid">
                            {grid2.map(cell => (
                                cell.empty ? (
                                    <div class="cal-mini-day empty"></div>
                                ) : cell.events.length > 0 ? (
                                    <div class="cal-mini-day has-event">
                                        {cell.day}
                                        <div class="cal-popup">
                                            {cell.events.map(ev => (
                                                <div class="cal-popup-event">
                                                    <strong>{ev.title}</strong>
                                                    {ev.time && <span class="cal-popup-time">{ev.time}</span>}
                                                    <p>{ev.description}</p>
                                                </div>
                                            ))}
                                            <a href="https://wa.me/77070357777" class="cal-btn-wa" target="_blank">Принять участие</a>
                                        </div>
                                    </div>
                                ) : (
                                    <div class="cal-mini-day">{cell.day}</div>
                                )
                            ))}
                        </div>
                    </div>
                </div>
            </div>

            
        </div>
        <!-- MINIMALIST AUDIENCE INTEGRATION -->
        <div class="calendar-footer-image reveal reveal-d2">
            <Image src={audienceImg} alt="Аудитория BizPride на бизнес-мероприятии в Алматы" widths={[400, 800, 1024]} sizes="(max-width: 768px) 100vw, 1024px" quality={82} loading="lazy" decoding="async" />
        </div>
    </section>



    <!-- Schema.org Data (Event) -->
    <script type="application/ld+json" set:html={JSON.stringify([
        {
            "@context": "https://schema.org",
            "@type": "Event",
            "name": "Бизнес-Бранч BizPride",
            "description": "Еженедельный бизнес-бранч для предпринимателей: нетворкинг и обмен контактами.",
            "startDate": `${schemaDate}T12:00:00+05:00`,
            "endDate": `${schemaDate}T15:00:00+05:00`,
            "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
            "eventStatus": "https://schema.org/EventScheduled",
            "image": "https://bizpride.kz/img-mastermind.png",
            "performer": {
                "@type": "Organization",
                "name": "BizPride Club",
                "url": "https://bizpride.kz"
            },
            "location": {
                "@type": "Place",
                "name": "BizPride Club",
                "address": {
                    "@type": "PostalAddress",
                    "addressLocality": "Алматы",
                    "addressCountry": "KZ"
                }
            },
            "offers": {
                "@type": "Offer",
                "url": "https://wa.me/77070357777",
                "price": "0",
                "priceCurrency": "KZT",
                "availability": "https://schema.org/InStock"
            },
            "organizer": {
                "@type": "Organization",
                "name": "BizPride Club",
                "url": "https://bizpride.kz"
            }
        },
        {
            "@context": "https://schema.org",
            "@type": "Event",
            "name": "СОВЕТ ДИРЕКТОРОВ BizPride",
            "description": "Еженедельный глубокий разбор бизнес-кейсов для предпринимателей.",
            "startDate": `${month1.year}-${String(month1.month + 1).padStart(2, '0')}-${String((() => { for (let d = 1; d <= getDaysInMonth(month1.year, month1.month); d++) { if (new Date(month1.year, month1.month, d).getDay() === 2) return d; } return 1; })()).padStart(2, '0')}T09:00:00+05:00`,
            "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
            "eventStatus": "https://schema.org/EventScheduled",
            "location": {
                "@type": "Place",
                "name": "BizPride Club",
                "address": {
                    "@type": "PostalAddress",
                    "addressLocality": "Алматы",
                    "addressCountry": "KZ"
                }
            },
            "organizer": {
                "@type": "Organization",
                "name": "BizPride Club",
                "url": "https://bizpride.kz"
            }
        }
    ])} />

    <!-- In-content section: prose links to relevant blog articles -->
    <section style="background: var(--bg-secondary, #161922); padding: 80px 24px; border-top: 1px solid rgba(255,255,255,0.08);">
        <div style="max-width: 760px; margin: 0 auto;">
            <h2 style="font-size: clamp(28px, 4vw, 40px); font-weight: 800; color: #fff; margin: 0 0 24px;">Какие форматы встреч мы проводим</h2>
            <p style="font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: 18px;">
                Каждую субботу — открытый <a href="/blog/business-meropriyatiya-almaty-2026/" style="color: var(--red); text-decoration: underline;">бизнес-бранч</a> в премиальных ресторанах Алматы. Это формат для знакомства с сообществом: спикер, нетворкинг, speed-dating. Можно прийти в гостевом статусе без обязательств.
            </p>
            <p style="font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: 18px;">
                Каждый вторник — <a href="/blog/chto-takoe-mastermind/" style="color: var(--red); text-decoration: underline;">мастермайнд</a> для резидентов. Это закрытая фокус-группа из 6-10 собственников, где мы по жёсткому регламенту разбираем реальные кейсы участников. <a href="/blog/mastermind-v-bizpride/" style="color: var(--red); text-decoration: underline;">Подробный сценарий мастермайнда BizPride</a> — в отдельной статье.
            </p>
            <p style="font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: 18px;">
                Раз в месяц — турниры по игре Cashflow в нашей <a href="/blog/cashflow-almaty/" style="color: var(--red); text-decoration: underline;">казахстанской версии</a>. Раз в квартал — стратегические выезды только для резидентов.
            </p>
            <p style="font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7;">
                Если впервые слышите о бизнес-клубах — рекомендуем сначала посмотреть <a href="/blog/chto-takoe-business-club/" style="color: var(--red); text-decoration: underline;">обзор формата</a> и <a href="/blog/luchshie-business-cluby-almaty/" style="color: var(--red); text-decoration: underline;">сравнение площадок Алматы</a>.
            </p>
        </div>
    </section>

    <BlogTeaser
        slugs={[
            'business-meropriyatiya-almaty-2026',
            'mastermind-v-bizpride',
            'chto-takoe-mastermind'
        ]}
        heading="Что почитать перед встречей"
        intro="Календарь главных бизнес-мероприятий Алматы 2026, разбор формата мастермайндов и сценарий встречи в BizPride."
    />
</Layout>

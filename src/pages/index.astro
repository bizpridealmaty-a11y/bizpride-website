    <script is:inline>
        // Animated counter
        function animateCounters() {
            document.querySelectorAll('[data-count]').forEach(el => {
                const target = parseInt(el.dataset.count);
                const suffix = el.dataset.suffix || '';
                let current = 0;
                const step = Math.max(1, Math.floor(target / 40));
                const timer = setInterval(() => {
                    current += step;
                    if (current >= target) { current = target; clearInterval(timer); }
                    el.textContent = current + suffix;
                }, 30);
            });
        }

        function initStats() {
            const statsObs = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) { animateCounters(); statsObs.disconnect(); }
                });
            }, { threshold: 0.3 });
            const statsElements = document.querySelectorAll('.stats-bar, .fmt-stats-block');
            statsElements.forEach(el => statsObs.observe(el));
        }

        // Initialize on page load/transition
        document.addEventListener('astro:page-load', initStats);
    </script>

---
import Layout from '../layouts/Layout.astro';
import { client, urlFor } from '../lib/sanity';

const albums = await client.fetch(`*[_type == "photoAlbum"] | order(order asc, _createdAt desc)`);

import residents from '../data/residents.js';
---

<Layout 
    title="BizPride Club (БизПрайд) — Клуб для предпринимателей в Алматы"
    description="Предприниматели Алматы объединяются в BizPride (БизПрайд) — клубе для предпринимателей в Алматы. Нетворкинг-ужины, мастермайнды и открытое сообщество лидеров бизнеса."
>
    <!-- HERO (Strict Solid Dark Layout) -->
<style is:global>
        .hero-mockup-wrapper {
            font-family: 'Montserrat', sans-serif !important;
            background-color: #050505;
            color: #ffffff;
            width: 100%;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            position: relative;
        }

        .hero-mockup-wrapper::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            box-shadow: inset 300px 0 200px -100px #050505, inset -300px 0 200px -100px #050505;
            z-index: 5;
        }
        
        .hero-mockup-wrapper * {
            font-family: 'Montserrat', sans-serif !important;
        }

        .hero-mockup-container {
            width: 100%;
            max-width: 1920px;
            margin: 0 auto;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .hm-bg-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            overflow: hidden;
        }

        .hm-bg-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center top;
            image-rendering: -webkit-optimize-contrast;
            image-rendering: high-quality;
        }

        .hm-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, rgba(0,0,0,0.98) 0%, rgba(0,0,0,0.85) 35%, rgba(0,0,0,0) 45%, rgba(0,0,0,0) 55%, rgba(0,0,0,0.7) 75%, rgba(0,0,0,0.98) 100%);
        }

        .hm-main-content {
            position: relative;
            z-index: 10;
            display: flex;
            padding: 100px;
            flex-grow: 1;
            align-items: center;
            justify-content: space-between;
        }

        .hm-left-col {
            flex: 1;
            padding-right: 50px;
            max-width: 60%;
        }

        .hm-geo-tag {
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 2px;
            color: #ddd;
            margin-bottom: 20px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            
            /* Glass Badge Styling */
            background: rgba(20, 20, 20, 0.6);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            padding: 8px 20px;
            border-radius: 30px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .hm-geo-tag i { color: #EE303E; }

        .hm-h1 {
            font-size: 120px;
            line-height: 0.9;
            font-weight: 900;
            text-transform: uppercase;
            margin-bottom: 20px;
            margin-top: 0;
            letter-spacing: normal;
        }

        .hm-title-red { color: #EE303E; display: block; }
        .hm-title-white { color: #fff; display: block; }

        .hm-subtitle {
            font-size: 32px;
            font-weight: 300;
            font-style: italic;
            color: #ccc;
            margin-bottom: 30px;
            border-left: 4px solid #EE303E;
            padding-left: 20px;
        }

        .hm-description {
            font-size: 18px;
            line-height: 1.6;
            color: #aaa;
            max-width: 600px;
            margin-bottom: 50px;
            font-weight: 400;
        }

        .hm-actions {
            display: flex;
            gap: 20px;
        }

        .hm-btn-primary {
            background-color: #EE303E;
            color: #fff;
            padding: 18px 40px;
            font-size: 16px;
            font-weight: 700;
            text-transform: uppercase;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .hm-btn-outline {
            background-color: transparent;
            color: #fff;
            padding: 18px 40px;
            font-size: 16px;
            font-weight: 700;
            text-transform: uppercase;
            border: 2px solid rgba(255,255,255,0.3);
            border-radius: 4px;
            cursor: pointer;
            letter-spacing: 1px;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .hm-btn-outline:hover {
            border-color: #fff;
            background-color: rgba(255,255,255,0.1);
        }

        .hm-right-col {
            width: 450px;
            display: flex;
            flex-direction: column;
            margin-top: 50px;
            position: relative;
        }

        .hm-card {
            background: rgba(20, 20, 20, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 30px;
            border-radius: 12px;
            position: relative;
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            margin-bottom: -30px; /* Chaotic overlap */
            transform-origin: center right;
        }
        
        .hm-card:last-child {
            margin-bottom: 0;
        }

        /* Staggered chaotic transforms */
        .hm-card:nth-child(1) {
            transform: translateX(-20px) rotate(-2deg);
            z-index: 3;
        }
        .hm-card:nth-child(2) {
            transform: translateX(15px) rotate(1deg);
            z-index: 2;
        }
        .hm-card:nth-child(3) {
            transform: translateX(-10px) rotate(-1deg);
            z-index: 1;
        }

        /* Massive 1.5x Interactive Pop */
        .hm-card:hover { 
            transform: scale(1.4) rotate(0deg) translateX(-10px); 
            z-index: 100 !important; 
            border-color: rgba(238, 48, 62, 0.8); 
            background: rgba(20, 20, 20, 0.95);
            box-shadow: -20px 30px 60px rgba(0,0,0,0.6);
        }

        .hm-card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 15px;
        }

        .hm-card-title {
            font-size: 20px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #fff;
        }
        
        .hm-card-title.highlight { color: #EE303E; }

        .hm-card-icon {
            font-size: 24px;
            color: #EE303E;
            background: rgba(238, 48, 62, 0.1);
            padding: 10px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
        }

        .hm-card-desc {
            font-size: 14px;
            color: #aaa;
            margin-bottom: 20px;
            line-height: 1.5;
        }

        .hm-card-stats {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-top: 10px;
        }

        .hm-avatar-group { display: flex; }

        .hm-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 2px solid #1a1a1a;
            background-color: #333;
            margin-left: -12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            color: #fff;
            background-size: cover;
            background-position: center;
            font-weight: 700;
        }
        
        .hm-avatar:first-child { margin-left: 0; background-image: url('https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=64&h=64'); }
        .hm-avatar:nth-child(2) { background-image: url('https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?auto=format&fit=crop&w=64&h=64'); }
        .hm-avatar:nth-child(3) { background-image: url('https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=64&h=64'); }

        .hm-btn-card {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            color: #EE303E;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .hm-event-date {
            font-size: 32px;
            font-weight: 800;
            color: #fff;
            line-height: 1;
        }
        
        .hm-event-month {
            font-size: 14px;
            color: #888;
            text-transform: uppercase;
            margin-bottom: 5px;
            display: block;
            letter-spacing: 1px;
        }
        
        .hm-stat-label {
            font-size: 12px;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 500;
            margin-top: 5px;
        }

        .hm-stats-bar-wrapper {
            position: relative;
            z-index: 10;
            width: 100%;
            overflow: hidden;
            border-top: 1px solid rgba(255,255,255,0.1);
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            padding: 20px 0;
            display: flex;
        }

        .hm-stats-marquee {
            display: flex;
            align-items: center;
            width: max-content;
            animation: hm-scroll 40s linear infinite;
        }

        .hm-stats-marquee:hover {
            animation-play-state: paused;
        }

        @keyframes hm-scroll {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        .hm-stat-item {
            display: flex;
            flex-direction: column;
            gap: 5px;
            margin: 0 40px;
            padding: 15px 30px;
            background: rgba(255,255,255,0.03);
            border-radius: 12px;
            border: 1px solid transparent;
            min-width: 180px;
            white-space: nowrap;
            transition: all 0.3s ease;
        }

        .hm-stat-item:hover {
            transform: scale(1.1) translateY(-5px);
            background: rgba(20,20,20,0.8);
            border-color: rgba(238, 48, 62, 0.5);
            box-shadow: 0 10px 20px rgba(0,0,0,0.5);
        }

        .hm-stat-value {
            font-size: 28px;
            font-weight: 800;
            color: #fff;
            white-space: nowrap;
        }

        .hm-red-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            background-color: #EE303E;
            border-radius: 50%;
            margin-right: 8px;
            vertical-align: middle;
        }

        .hm-decorative-line {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 5px;
            height: 100%;
            background: #EE303E;
        }

        @media (max-width: 1024px) {
            .hm-main-content {
                flex-direction: column;
                padding: 50px 20px;
            }
            .hm-left-col, .hm-right-col {
                max-width: 100%;
                width: 100%;
                padding-right: 0;
            }
            .hm-h1 { font-size: 60px; }
            .hm-stat-item { margin: 0 20px; min-width: 140px; }
            .hm-stat-value { font-size: 22px; }

            /* ── Mobile Card Reset ── */
            .hm-right-col {
                margin-top: 30px;
                gap: 12px;
            }
            .hm-card {
                margin-bottom: 0 !important;
                padding: 20px;
            }
            .hm-card:nth-child(1),
            .hm-card:nth-child(2),
            .hm-card:nth-child(3) {
                transform: none !important;
            }
            .hm-card:hover {
                transform: scale(1.03) !important;
                box-shadow: 0 8px 24px rgba(0,0,0,0.4);
            }
            .hm-card-title { font-size: 16px; }
            .hm-card-desc { font-size: 13px; }
            .hm-card-icon { width: 36px; height: 36px; font-size: 18px; padding: 7px; }
            .hm-event-date { font-size: 28px; }
            .hm-btn-card { font-size: 12px; }
        }
</style>

    <div class="hero-mockup-wrapper" id="home">
        <!-- Background Layer (Moved outside container for true Full Width) -->
        <div class="hm-bg-layer">
            <img src="/founder.png?v=4" alt="Основатель BizPride" class="hm-bg-image">
            <div class="hm-overlay"></div>
        </div>
        <div class="hero-mockup-container">

            <!-- Main Content -->
            <div class="hm-main-content">
                <!-- Left Column -->
                <div class="hm-left-col">
                    <div class="hm-geo-tag">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="#EE303E"><path d="M12 2c4.2 0 8 3.22 8 8.2 0 3.18-2.45 6.92-7.34 11.23a1.05 1.05 0 0 1-1.32 0C6.45 17.12 4 13.38 4 10.2 4 5.22 7.8 2 12 2zm0 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5z"/></svg> АЛМАТЫ • БИЗНЕС-КЛУБ
                    </div>
                    <h1 class="hm-h1">
                        <span class="hm-title-red">BizPride</span>
                        <span class="hm-title-white">Club</span>
                    </h1>
                    <div class="hm-subtitle">Открытое сообщество лидеров</div>
                    <p class="hm-description">
                        Премиальное пространство для нетворкинга, обмена опытом и развития вашего бизнеса. Объединяем сильнейших предпринимателей страны для создания будущего.
                    </p>
                    <div class="hm-actions">
                        <a href="/#membership" class="hm-btn-primary">
                            Стать резидентом
                        </a>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="hm-right-col">
                    <!-- Card 1 -->
                    <div class="hm-card">
                        <div class="hm-decorative-line"></div>
                        <div class="hm-card-header">
                            <div class="hm-card-title">120+ Резидентов</div>
                            <div class="hm-card-icon"><svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" fill="currentColor"/></svg></div>
                        </div>
                        <div class="hm-card-desc">Топовые предприниматели и эксперты из разных сфер бизнеса.</div>
                        <div class="hm-card-stats">
                            <div class="hm-avatar-group">
                                <div class="hm-avatar"></div>
                                <div class="hm-avatar"></div>
                                <div class="hm-avatar"></div>
                                <div class="hm-avatar">+99</div>
                            </div>
                            <a href="/residents" class="hm-btn-card">Все резиденты <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg></a>
                        </div>
                    </div>

                    <!-- Card 2 -->
                    <div class="hm-card">
                        <div class="hm-card-header">
                            <div>
                                <span class="hm-event-month">Сентябрь 2023</span>
                                <div class="hm-card-title highlight">Ближайшие события</div>
                            </div>
                            <div class="hm-card-icon"><svg viewBox="0 0 24 24"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2zm-7 5h5v5h-5z" fill="currentColor"/></svg></div>
                        </div>
                        <div style="display: flex; gap: 20px; margin-top: 10px;">
                            <div>
                                <div class="hm-event-date">12</div>
                                <div class="hm-stat-label">Networking</div>
                            </div>
                            <div>
                                <div class="hm-event-date">24</div>
                                <div class="hm-stat-label">Business Talk</div>
                            </div>
                        </div>
                        <a href="/events" class="hm-btn-card" style="margin-top: 15px;">Календарь встреч <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg></a>
                    </div>

                    <!-- Card 3 -->
                    <div class="hm-card">
                        <div class="hm-card-header">
                            <div class="hm-card-title">Форматы встреч</div>
                            <div class="hm-card-icon"><svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" fill="currentColor"/></svg></div>
                        </div>
                        <div class="hm-card-desc">Бизнес-завтраки, форумы, закрытые ужины и спортивные мероприятия.</div>
                        <a href="/#values" class="hm-btn-card">Узнать подробнее <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg></a>
                    </div>
                </div>
            </div>

            <!-- Stats Bar (Animated Marquee) -->
            <div class="hm-stats-bar-wrapper">
                <div class="hm-stats-marquee">
                    <!-- Set 1 -->
                    <div class="hm-stat-item">
                        <div class="hm-stat-value">KZ / RU / EN</div>
                        <div class="hm-stat-label">Языки встреч</div>
                    </div>
                    <div class="hm-stat-item">
                        <div class="hm-stat-value">120+</div>
                        <div class="hm-stat-label">Резидентов</div>
                    </div>
                    <div class="hm-stat-item">
                        <div class="hm-stat-value">4.8/5</div>
                        <div class="hm-stat-label">Рейтинг NPS</div>
                    </div>
                    <div class="hm-stat-item">
                        <div class="hm-stat-value">50+</div>
                        <div class="hm-stat-label">Спикеров</div>
                    </div>
                    <div class="hm-stat-item">
                        <div class="hm-stat-value">Offline</div>
                        <div class="hm-stat-label">Основной формат</div>
                    </div>
                    <div class="hm-stat-item">
                        <div class="hm-stat-value">$1M+</div>
                        <div class="hm-stat-label">Оборот участников</div>
                    </div>
                    <div class="hm-stat-item">
                        <div class="hm-stat-value"><span class="hm-red-dot"></span>Active</div>
                        <div class="hm-stat-label">Статус клуба</div>
                    </div>

                    <!-- Set 2 (Cloned for seamless infinite scroll) -->
                    <div class="hm-stat-item">
                        <div class="hm-stat-value">KZ / RU / EN</div>
                        <div class="hm-stat-label">Языки встреч</div>
                    </div>
                    <div class="hm-stat-item">
                        <div class="hm-stat-value">120+</div>
                        <div class="hm-stat-label">Резидентов</div>
                    </div>
                    <div class="hm-stat-item">
                        <div class="hm-stat-value">4.8/5</div>
                        <div class="hm-stat-label">Рейтинг NPS</div>
                    </div>
                    <div class="hm-stat-item">
                        <div class="hm-stat-value">50+</div>
                        <div class="hm-stat-label">Спикеров</div>
                    </div>
                    <div class="hm-stat-item">
                        <div class="hm-stat-value">Offline</div>
                        <div class="hm-stat-label">Основной формат</div>
                    </div>
                    <div class="hm-stat-item">
                        <div class="hm-stat-value">$1M+</div>
                        <div class="hm-stat-label">Оборот участников</div>
                    </div>
                    <div class="hm-stat-item">
                        <div class="hm-stat-value"><span class="hm-red-dot"></span>Active</div>
                        <div class="hm-stat-label">Статус клуба</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- VALUES -->
    <section class="section-dark" id="values" style="background: var(--bg-secondary);">
        <div class="container">
            <div class="values-header">
                <div class="label reveal">Ценности</div>
                <h2 class="heading-lg reveal reveal-d1">Почему выбирают<br>наш клуб</h2>
            </div>

            <div class="values-grid">
                <div class="value-card reveal">
                    <div class="vc-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
                    <h3>Окружение</h3>
                    <p>Доступ к кругу сильных лидеров, которые сталкиваются с такими же вызовами и готовы делиться опытом.</p>
                </div>
                <div class="value-card reveal reveal-d1">
                    <div class="vc-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div>
                    <h3>Развитие</h3>
                    <p>Проверенные форматы встреч, ориентированные на конкретный результат в бизнесе и личностный рост.</p>
                </div>
                <div class="value-card reveal reveal-d2">
                    <div class="vc-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
                    <h3>Доверие</h3>
                    <p>Открытая среда, где соблюдаются правила конфиденциальности и действует принцип WIN-WIN.</p>

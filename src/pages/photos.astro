---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { client, urlFor } from '../lib/sanity';

const sanityAlbums = await client.fetch(`*[_type == "photoAlbum"] | order(order asc, _createdAt desc)`);

const albums = [
    {
        title: 'Куда нужно инвестировать',
        date: '18.04.2026',
        googleDriveLink: 'https://mainslow.wfolio.pro/disk/18-04-2026-bizpride-tdc3bt',
        staticCover: '/img-album-investments.webp'
    },
    {
        title: '«Одних слушают, других терпят»',
        date: '11.04.2026',
        googleDriveLink: 'https://mainslow.wfolio.pro/disk/11-04-2026-bizpride-41ttfg',
        staticCover: '/img-album-listen.webp'
    },
    {
        title: 'Налоги: как не платить в Казахстане',
        date: '28.03.2026',
        googleDriveLink: 'https://mainslow.wfolio.pro/disk/28-03-2026-bizpride-99hp2n',
        staticCover: '/img-album-taxes.webp'
    },
    {
        title: 'Бизнес-игра Ярд',
        date: '21.03.2026',
        googleDriveLink: 'https://mainslow.wfolio.pro/disk/21-03-2026-bizgame-7r2qs2',
        staticCover: '/img-album-bizgame.webp'
    },
    {
        title: 'Стратегическая сессия',
        date: '14.03.2026',
        googleDriveLink: 'https://mainslow.wfolio.pro/disk/14-03-2026-bizpride-085cwm',
        staticCover: '/img-album-strategy.webp'
    },
    {
        title: '«Как увеличить чистую прибыль» от 10 до 30%',
        date: '28.02.2026',
        googleDriveLink: 'https://mainslow.wfolio.pro/disk/28-02-2026-bizpride-qb7ndw',
        staticCover: '/img-album-profit.webp'
    },
    ...sanityAlbums
];

const padNum = (n: number) => String(n + 1).padStart(2, '0');
---

<Layout
    title="Фотогалерея BizPride — фотоотчёты с бранчей в Алматы"
    description="Фотографии с мастермайндов, бизнес-бранчей и выездов BizPride Club. Атмосфера сообщества предпринимателей Алматы."
>
    <section class="section-dark" style="padding-top: 110px;">
        <div class="container" style="padding-bottom: 32px;">
            <Breadcrumbs items={[
                { name: 'Главная', href: '/' },
                { name: 'Фотогалерея' }
            ]} />
        </div>
        <div class="container">
            <div class="gallery-header" style="flex-direction: column; align-items: flex-start; gap: 24px; margin-bottom: 80px;">
                <div>
                    <div class="label reveal" style="margin-bottom: 16px;">Свежие кадры</div>
                    <h1 class="heading-lg reveal reveal-d1" style="font-size: clamp(40px, 6vw, 72px); line-height: 1.05; letter-spacing: -2px;">Фотоотчёты<br>с мероприятий BizPride</h1>
                </div>
                <p class="reveal reveal-d2" style="color: var(--text-light); font-size: 18px; max-width: 640px; line-height: 1.7; opacity: 0.8;">
                    На этой странице мы сохраняем историю наших встреч. Находите себя на фотоотчётах, делитесь моментами и следите за жизнью нашего сообщества.
                </p>
            </div>

            <div class="albums-bento">
                {albums.map((album, index) => {
                    const cover = album.staticCover
                        ? album.staticCover
                        : (album.coverImage ? urlFor(album.coverImage).width(1200).url() : null);
                    return (
                        <a
                            href={album.googleDriveLink}
                            target="_blank"
                            rel="noopener"
                            class={`bento-card reveal ${index === 0 ? 'bento-hero' : ''} ${index > 0 ? 'reveal-d' + Math.min(index, 3) : ''}`}
                            aria-label={`Альбом «${album.title}» — ${album.date}`}
                        >
                            {cover && <img class="bento-img" src={cover} alt={album.title} loading={index < 3 ? 'eager' : 'lazy'} />}
                            <span class="bento-number">{padNum(index)}</span>
                            <div class="bento-overlay">
                                <span class="bento-badge">{album.date}</span>
                                <div class="bento-bottom">
                                    <span class="bento-title">{album.title}</span>
                                    <span class="bento-cta">
                                        <span class="bento-cta-text">Смотреть</span>
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
                                    </span>
                                </div>
                            </div>
                        </a>
                    );
                })}
            </div>
        </div>
    </section>

    <style>
        /* ═══ BENTO PHOTO GALLERY ═══ */
        .albums-bento {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
        }

        .albums-bento .bento-hero {
            grid-column: 1 / -1;
            aspect-ratio: 21/9;
        }

        .albums-bento .bento-card:not(.bento-hero):nth-child(2) {
            grid-column: span 2;
            aspect-ratio: 16/9;
        }

        .albums-bento .bento-card:not(.bento-hero):nth-child(3) {
            grid-column: span 1;
            aspect-ratio: 3/4;
        }

        .bento-card {
            position: relative;
            display: block;
            border-radius: 16px;
            overflow: hidden;
            cursor: pointer;
            aspect-ratio: 4/3;
            background: var(--bg-card, #161922);
            border: 1px solid rgba(255, 255, 255, 0.06);
            transition: all .5s cubic-bezier(0.16, 1, 0.3, 1);
            text-decoration: none;
        }

        .bento-card:hover {
            transform: translateY(-6px) scale(1.01);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(196, 43, 43, 0.2);
            border-color: rgba(196, 43, 43, 0.3);
            z-index: 2;
        }

        .bento-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .8s cubic-bezier(0.16, 1, 0.3, 1);
            will-change: transform;
        }

        .bento-card:hover .bento-img {
            transform: scale(1.08);
        }

        .bento-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(0, 0, 0, 0.1) 0%, transparent 30%, transparent 50%, rgba(0, 0, 0, 0.7) 80%, rgba(0, 0, 0, 0.95) 100%);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 20px;
            transition: all 0.4s;
        }

        .bento-hero .bento-overlay {
            padding: 28px 32px;
        }

        .bento-badge {
            align-self: flex-start;
            background: rgba(255, 255, 255, 0.12);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: #fff;
        }

        .bento-card:hover .bento-badge {
            background: var(--red, #c42b2b);
            border-color: var(--red, #c42b2b);
        }

        .bento-bottom {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 16px;
        }

        .bento-title {
            font-size: 18px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #fff;
            line-height: 1.2;
            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
        }

        .bento-hero .bento-title {
            font-size: clamp(22px, 2.5vw, 32px);
        }

        .bento-cta {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-shrink: 0;
            padding: 8px 16px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            opacity: 0;
            transform: translateY(8px);
        }

        .bento-card:hover .bento-cta {
            opacity: 1;
            transform: translateY(0);
            background: var(--red, #c42b2b);
            border-color: var(--red, #c42b2b);
        }

        .bento-cta-text {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: #fff;
            white-space: nowrap;
        }

        .bento-cta svg {
            width: 14px;
            height: 14px;
            color: #fff;
            transition: transform 0.3s;
        }

        .bento-card:hover .bento-cta svg {
            transform: translate(2px, -2px);
        }

        .bento-number {
            position: absolute;
            top: 20px;
            right: 20px;
            font-size: 48px;
            font-weight: 900;
            color: rgba(255, 255, 255, 0.06);
            line-height: 1;
            pointer-events: none;
            transition: all 0.5s;
        }

        .bento-hero .bento-number {
            font-size: 72px;
        }

        .bento-card:hover .bento-number {
            color: rgba(196, 43, 43, 0.15);
            transform: scale(1.1);
        }

        @media (max-width: 900px) {
            .albums-bento { grid-template-columns: repeat(2, 1fr); }
            .albums-bento .bento-card:not(.bento-hero):nth-child(2) { grid-column: span 2; aspect-ratio: 16/9; }
            .albums-bento .bento-card:not(.bento-hero):nth-child(3) { grid-column: span 1; aspect-ratio: 1/1; }
        }

        @media (max-width: 600px) {
            .albums-bento { grid-template-columns: 1fr; }
            .albums-bento .bento-card,
            .albums-bento .bento-hero,
            .albums-bento .bento-card:not(.bento-hero):nth-child(2),
            .albums-bento .bento-card:not(.bento-hero):nth-child(3) {
                grid-column: span 1;
                aspect-ratio: 4/3;
            }
            .bento-cta { opacity: 1; transform: none; }
        }
    </style>
</Layout>

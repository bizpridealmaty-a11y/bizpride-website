---
import Layout from '../layouts/Layout.astro';
import { client, urlFor } from '../lib/sanity';

const sanityAlbums = await client.fetch(`*[_type == "photoAlbum"] | order(order asc, _createdAt desc)`);

const albums = [
    {
        title: '«Одних слушают, других терпят»',
        date: '11.04.2026',
        googleDriveLink: 'https://mainslow.wfolio.pro/disk/11-04-2026-bizpride-41ttfg',
        staticCover: '/img-album-listen.jpg'
    },
    {
        title: 'Family Day — Медвежий водопад',
        date: '04.04.2026',
        googleDriveLink: 'https://drive.google.com/drive/folders/1SIcO4K-skeOqJFzk3vJFK48O0dQb0-b0',
        staticCover: '/img-album-familyday.jpg'
    },
    {
        title: 'Налоги: как не платить в Казахстане',
        date: '28.03.2026',
        googleDriveLink: 'https://mainslow.wfolio.pro/disk/28-03-2026-bizpride-99hp2n',
        staticCover: '/img-album-taxes.jpg'
    },
    {
        title: 'Бизнес-игра Ярд',
        date: '21.03.2026',
        googleDriveLink: 'https://mainslow.wfolio.pro/disk/21-03-2026-bizgame-7r2qs2',
        staticCover: '/img-album-bizgame.jpg'
    },
    {
        title: 'Стратегическая сессия',
        date: '14.03.2026',
        googleDriveLink: 'https://mainslow.wfolio.pro/disk/14-03-2026-bizpride-085cwm',
        staticCover: '/img-album-strategy.jpg'
    },
    {
        title: '«Как увеличить чистую прибыль» от 10 до 30%',
        date: '28.02.2026',
        googleDriveLink: 'https://mainslow.wfolio.pro/disk/28-02-2026-bizpride-qb7ndw',
        staticCover: '/img-album-profit.jpg'
    },
    ...sanityAlbums
];
---

<Layout 
    title="Фотогалерея BizPride Club — Моменты наших встреч"
    description="Смотрите фотоотчеты с мастермайндов, бранчей и клубных выездов BizPride Club. Живая атмосфера нашего сообщества в Алматы."
>
    <section class="section-dark" style="padding-top: 180px;">
        <div class="container">
            <div class="gallery-header" style="flex-direction: column; align-items: flex-start; gap: 24px; margin-bottom: 80px;">
                <div>
                    <div class="label reveal" style="margin-bottom: 16px;">Свежие кадры</div>
                    <h2 class="heading-lg reveal reveal-d1" style="font-size: clamp(40px, 6vw, 72px); line-height: 1.05; letter-spacing: -2px;">Фотоотчёты<br>с мероприятий</h2>
                </div>
                <p class="reveal reveal-d2" style="color: var(--text-light); font-size: 18px; max-width: 640px; line-height: 1.7; opacity: 0.8;">
                    На этой странице мы сохраняем историю наших встреч. Находите себя на фотоотчётах, делитесь моментами и следите за жизнью нашего сообщества.
                </p>
            </div>

            <div class="albums-bento">
                {albums.map((album, index) => (
                    <a 
                        href={album.googleDriveLink} 
                        target="_blank" 
                        rel="noopener"
                        class={`bento-card ${index === 0 ? 'bento-hero' : ''} reveal ${index > 0 ? 'reveal-d' + Math.min(index, 3) : ''}`}
                        style="display:block; text-decoration:none;"
                    >
                        {album.staticCover ? (
                            <img class="bento-img" src={album.staticCover} alt={album.title} loading={index < 3 ? "eager" : "lazy"} />
                        ) : album.coverImage ? (
                            <img class="bento-img" src={urlFor(album.coverImage).width(800).url()} alt={album.title} loading="lazy" />
                        ) : null}
                        <div class="bento-overlay">
                            <div class="bento-badge">{album.date}</div>
                            <div class="bento-bottom">
                                <div class="bento-title">{album.title}</div>
                                <div class="bento-cta">
                                    <span class="bento-cta-text">Открыть альбом</span>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
                                </div>
                            </div>
                        </div>
                        <div class="bento-number">{String(index + 1).padStart(2, '0')}</div>
                    </a>
                ))}
            </div>
        </div>
    </section>
</Layout>
